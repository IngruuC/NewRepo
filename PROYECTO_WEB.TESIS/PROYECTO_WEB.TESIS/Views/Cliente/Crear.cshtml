@model ENTIDADES.Cliente
@{
    ViewData["Title"] = "Nuevo Cliente";
}
<h2>Nuevo Cliente</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Crear" method="post">
            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            <div class="mb-2"><label asp-for="Documento" class="form-label">Documento (8 dígitos)</label><input asp-for="Documento" class="form-control" maxlength="8" /></div>
            <div class="mb-2"><label asp-for="Nombre" class="form-label">Nombre</label><input asp-for="Nombre" class="form-control" /></div>
            <div class="mb-2"><label asp-for="Apellido" class="form-label">Apellido</label><input asp-for="Apellido" class="form-control" /></div>
            <div class="mb-2"><label asp-for="Direccion" class="form-label">Dirección</label><input asp-for="Direccion" class="form-control" /></div>
            <button type="submit" class="btn btn-success">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div></div>