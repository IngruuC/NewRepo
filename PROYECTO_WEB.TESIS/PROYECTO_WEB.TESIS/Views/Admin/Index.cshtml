@* ══════════════════════════════════════════════
   PANEL: NUEVA VENTA
   ══════════════════════════════════════════════ *@
<div class="panel" id="panel-nueva-venta">
    <div class="panel-header">
        <img src="~/images/icon-venta.png" alt="" onerror="this.style.display='none'" />
        <h3>NUEVA VENTA</h3>
    </div>
    <div class="panel-full">
        <form asp-controller="Venta" asp-action="Crear" method="post">
            <input type="hidden" name="__panel" value="nueva-venta" />
            <div class="panel-row">
                <div class="panel-field">
                    <label>CLIENTE</label>
                    <select name="ClienteId">
                        <option value="">— Seleccione cliente —</option>
                        @foreach (var c in ViewBag.Clientes as List<ENTIDADES.Cliente> ?? new List<ENTIDADES.Cliente>())
                        {
                            <option value="@c.Id">@c.DatosCompletos</option>
                        }
                    </select>
                </div>
                <div class="panel-field">
                    <label>FORMA DE PAGO</label>
                    <select name="FormaPago">
                        <option value="Efectivo">Efectivo (15% desc.)</option>
                        <option value="Tarjeta de Crédito">Tarjeta de Crédito (10% rec.)</option>
                        <option value="Tarjeta de Débito">Tarjeta de Débito</option>
                    </select>
                </div>
            </div>
            <div class="sub-title">AGREGAR PRODUCTO</div>
            <div class="agregar-row">
                <div class="panel-field">
                    <label>PRODUCTO</label>
                    <select id="venta-sel-producto">
                        <option value="">— Seleccione —</option>
                        @{
                            var promosVigentes = ViewBag.PromocionesVigentes as List<ENTIDADES.Promocion> ?? new List<ENTIDADES.Promocion>();
                        }
                        @foreach (var p in ViewBag.Productos as List<ENTIDADES.Producto> ?? new List<ENTIDADES.Producto>())
                        {
                            var promo = promosVigentes.FirstOrDefault(pr => pr.ProductoId == p.Id);
                            var precioFinal = promo != null ? promo.AplicarDescuento(p.Precio) : p.Precio;
                            var labelPromo = promo != null ? " 🏷️ PROMO" : "";
                            <option value="@p.Id"
                                    data-precio="@precioFinal"
                                    data-preciooriginal="@p.Precio"
                                    data-nombre="@p.Nombre"
                                    data-stock="@p.Stock"
                                    data-tienepromo="@(promo != null ? "true" : "false")">
                                @p.Nombre@labelPromo — $@precioFinal.ToString("N2") (Stock: @p.Stock)
                            </option>
                        }
                    </select>
                </div>
                <div class="panel-field small">
                    <label>CANTIDAD</label>
                    <input type="number" id="venta-cantidad" min="1" value="1" />
                </div>
                <button type="button" class="btn-agregar" onclick="ventaAgregarProducto()">+ AGREGAR</button>
            </div>
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead><tr><th>Producto</th><th>Cantidad</th><th>Precio Unit.</th><th>Subtotal</th><th></th></tr></thead>
                    <tbody id="venta-tbody"><tr id="venta-empty-row"><td colspan="5" style="text-align:center;color:#aaa;padding:12px;">Agregue productos...</td></tr></tbody>
                </table>
            </div>
            <div class="total-row">TOTAL: $<span id="venta-total">0.00</span></div>
            <div id="venta-hidden-inputs"></div>
            <div style="display:flex;gap:8px;margin-top:10px;">
                <button type="submit" class="btn-finalizar" id="btn-finalizar-venta" disabled>FINALIZAR VENTA</button>
                <button type="button" class="btn-cancelar" onclick="ventaLimpiar()">LIMPIAR</button>
            </div>
        </form>
    </div>
</div>

@* ══════════════════════════════════════════════
