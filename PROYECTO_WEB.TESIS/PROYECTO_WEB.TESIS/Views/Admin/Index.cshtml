                <button class="btn-form-del" id="btn-vt-eliminar" onclick="ventaEliminarSeleccionada()" disabled>ELIMINAR</button>
                <button class="btn-form-save" style="background:#8e44ad;border-color:#6c3483;color:#fff" onclick="ventaMostrarEstadisticas()">ESTADÍSTICAS</button>
