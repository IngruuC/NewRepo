            </div>
        </div>
        <div class="panel-table-col">
            <div class="search-bar" style="flex-wrap:wrap;gap:5px;">
                <label class="vt-lbl">DESDE</label>
                <input type="date" id="vt-desde" class="vt-date" />
                <label class="vt-lbl">HASTA</label>
                <input type="date" id="vt-hasta" class="vt-date" />
                <button class="btn-search" onclick="filtrarVentasFecha()">BUSCAR</button>
                <button class="btn-clear" onclick="limpiarFiltroVentas()">LIMPIAR</button>
            </div>
            <div class="search-bar" style="margin-top:4px">
                <label>BUSCAR:</label>
                <input type="text" id="search-ventas" oninput="filtrarVentas(this.value)" placeholder="Cliente, forma de pago..." />
            </div>
            <div class="data-table-wrap">
                <table class="data-table" id="tabla-ventas">
                    <thead><tr><th>ID</th><th>Fecha</th><th>Cliente</th><th>Forma Pago</th><th>Total</th></tr></thead>
                    <tbody>
                        @foreach (var v in ViewBag.Ventas as List<ENTIDADES.Venta> ?? new List<ENTIDADES.Venta>())
                        {
                            <tr onclick="ventaSeleccionarFila(this, @v.Id)"
                                data-id="@v.Id" data-fecha="@v.FechaVenta.ToString("dd/MM/yyyy HH:mm")"
                                data-cliente="@v.Cliente?.ToString()" data-formapago="@v.FormaPago"
                                data-total="@v.Total.ToString("N2")"
                                data-detalles="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(v.Detalles.Select(d => new { nombre = d.ProductoNombre, cantidad = d.Cantidad, precio = d.PrecioUnitario.ToString("N2"), subtotal = d.Subtotal.ToString("N2") })).Replace("\"", "&quot;"))">
                                <td>@v.Id</td>
                                <td>@v.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@v.Cliente?.ToString()</td>
                                <td>@v.FormaPago</td>
                                <td>$@v.Total.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="total-row">TOTAL: $<span id="vt-total-label">@((ViewBag.Ventas as List<ENTIDADES.Venta> ?? new List<ENTIDADES.Venta>()).Sum(v => v.Total).ToString("N2"))</span></div>
            <form asp-controller="Venta" asp-action="Eliminar" method="post" id="form-vt-eliminar">
                <input type="hidden" name="id" id="vt-eliminar-id" />
                <input type="hidden" name="__panel" value="ventas-totales" />
            </form>
        </div>
    </div>
</div>

