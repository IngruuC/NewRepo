            </form>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════
   PANEL: PROMOCIONES
   ══════════════════════════════════════════════ *@
<div class="panel" id="panel-promociones">
    <div class="panel-header">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0">
            <path d="M2 2h6l8 8-6 6-8-8V2z" stroke="#3a2500" stroke-width="1.3" fill="none" stroke-linejoin="round" />
            <circle cx="6" cy="6" r="1.5" fill="#3a2500" />
        </svg>
        <h3>PROMOCIONES</h3>
    </div>
    <div class="panel-body">
        <div class="panel-form-col">
            <div class="form-box">
                <div class="form-section-title">NUEVA PROMOCIÓN</div>
                <div class="form-field">
                    <label>PRODUCTO:</label>
                    <select id="promo-producto" style="width:100%;border:1px solid #c8a000;border-radius:3px;padding:4px 6px;font-size:11px;background:#fffef0;">
                        <option value="">— Seleccione —</option>
                        @foreach (var p in ViewBag.TodosProductos as List<ENTIDADES.Producto> ?? new List<ENTIDADES.Producto>())
                        {
                            <option value="@p.Id" data-precio="@p.Precio">@p.Nombre ($@p.Precio.ToString("N2"))</option>
                        }
                    </select>
                </div>
                <div class="form-field">
                    <label>TIPO DE DESCUENTO:</label>
                    <select id="promo-tipo" style="width:100%;border:1px solid #c8a000;border-radius:3px;padding:4px 6px;font-size:11px;background:#fffef0;">
                        <option value="Porcentaje">Porcentaje (%)</option>
                        <option value="Monto">Monto ($)</option>
                    </select>
                </div>
                <div class="form-field">
                    <label id="promo-valor-lbl">VALOR (%):</label>
                    <input type="number" id="promo-valor" step="0.01" min="0" />
                </div>
                <div class="form-field">
                    <label>FECHA FIN:</label>
                    <input type="datetime-local" id="promo-fecha-fin" />
                </div>
                <div class="form-field">
                    <label>DESCRIPCIÓN:</label>
                    <input type="text" id="promo-desc" placeholder="Ej: Promo de verano" />
                </div>
                <form asp-controller="Promocion" asp-action="Crear" method="post" id="form-promo-crear">
                    <input type="hidden" name="ProductoId" id="h-promo-producto" />
                    <input type="hidden" name="TipoDescuento" id="h-promo-tipo" />
                    <input type="hidden" name="ValorDescuento" id="h-promo-valor" />
                    <input type="hidden" name="FechaFin" id="h-promo-fecha-fin" />
                    <input type="hidden" name="Descripcion" id="h-promo-desc" />
                    <input type="hidden" name="__panel" value="promociones" />
                </form>
                <button type="button" class="btn-form-save" onclick="promoCrear()">CREAR PROMOCIÓN</button>
                <div id="promo-preview" style="display:none;margin-top:8px;background:#eafaf1;border:1px solid #27ae60;border-radius:4px;padding:8px;font-size:11px;color:#1e8449;text-align:center;"></div>
            </div>
        </div>
        <div class="panel-table-col">
            <div class="search-bar" style="margin-bottom:6px;">
                <label>FILTRAR:</label>
                <select id="promo-filtro-estado" onchange="promoFiltrar()" style="border:1px solid #c8a000;border-radius:3px;padding:4px 6px;font-size:11px;background:#fffef0;">
                    <option value="">Todas</option>
                    <option value="vigente">Vigentes</option>
                    <option value="inactiva">Inactivas/Vencidas</option>
                </select>
            </div>
            <div class="data-table-wrap">
                <table class="data-table" id="tabla-promociones">
                    <thead>
                        <tr><th>Producto</th><th>Descuento</th><th>Descripción</th><th>Fecha Fin</th><th>Estado</th><th>Acciones</th></tr>
                    </thead>
                    <tbody id="promo-tbody">
                        <tr><td colspan="6" style="text-align:center;color:#aaa;padding:14px;">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════
   PANEL: SEGURIDAD
   ══════════════════════════════════════════════ *@
<div class="panel" id="panel-seguridad">
    <div class="panel-header">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0">
            <path d="M9 1L2 4v5c0 4 3.1 7.2 7 8 3.9-.8 7-4 7-8V4L9 1z" stroke="#3a2500" stroke-width="1.3" fill="none" />
        </svg>
        <h3>SEGURIDAD</h3>
    </div>
    <div class="panel-full">
        <div class="seg-menu" id="seg-menu-principal">
            <button class="seg-btn" onclick="mostrarSeccion('seg-grupos')">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <circle cx="9" cy="10" r="4" fill="#d4a017" />
                    <circle cx="19" cy="10" r="4" fill="#d4a017" />
                    <path d="M1 24c0-4 3.6-7 8-7" stroke="#d4a017" stroke-width="1.5" fill="none" />
                    <path d="M19 17c4.4 0 8 3 8 7" stroke="#d4a017" stroke-width="1.5" fill="none" />
                    <path d="M11 17h6" stroke="#d4a017" stroke-width="1.5" />
                </svg>
                <span>GESTIONAR GRUPOS</span>
            </button>
            <button class="seg-btn" onclick="mostrarSeccion('seg-usuarios')">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <circle cx="14" cy="9" r="5" fill="#d4a017" />
                    <path d="M3 26c0-6 4.9-11 11-11s11 5 11 11" stroke="#d4a017" stroke-width="1.5" fill="none" />
                </svg>
                <span>GESTIONAR USUARIOS</span>
            </button>
            <button class="seg-btn" onclick="mostrarSeccion('seg-auditoria')">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <circle cx="14" cy="14" r="11" stroke="#d4a017" stroke-width="1.5" fill="none" />
                    <line x1="14" y1="8" x2="14" y2="15" stroke="#d4a017" stroke-width="1.8" stroke-linecap="round" />
                    <circle cx="14" cy="19" r="1.2" fill="#d4a017" />
                </svg>
                <span>AUDITORÍA DE SESIONES</span>
            </button>
            <button class="seg-btn" onclick="mostrarSeccion('seg-backup')">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <rect x="3" y="5" width="22" height="18" rx="2" stroke="#d4a017" stroke-width="1.5" fill="none" />
                    <line x1="14" y1="10" x2="14" y2="18" stroke="#d4a017" stroke-width="1.5" stroke-linecap="round" />
                    <path d="M10 15l4 4 4-4" stroke="#d4a017" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    <line x1="9" y1="5" x2="9" y2="3" stroke="#d4a017" stroke-width="1.5" />
                    <line x1="19" y1="5" x2="19" y2="3" stroke="#d4a017" stroke-width="1.5" />
                </svg>
                <span>BACKUP</span>
            </button>
        </div>

        @* SUB: GRUPOS *@
        <div class="seg-seccion" id="seg-grupos" style="display:none">
            <div class="seg-form-header">
                <div class="seg-form-titulo">FrescoMarket — GESTIONAR GRUPOS</div>
                <button class="seg-btn-refrescar" onclick="sgGruposRefrescar()" title="Refrescar">↺</button>
            </div>
            <div class="seg-filtros-bar">
                <span class="seg-filtros-lbl">FILTROS</span>
                <label class="seg-flbl">NOMBRE:</label>
                <input type="text" id="sg-grp-fnombre" class="seg-finput" oninput="sgFiltrarGrupos()" />
                <label class="seg-flbl">ESTADO:</label>
                <select id="sg-grp-festado" class="seg-fselect" onchange="sgFiltrarGrupos()">
                    <option value="">Todos</option>
                    @foreach (var e in ViewBag.EstadosGrupo as List<ENTIDADES.SEGURIDAD.EstadoGrupo> ?? new List<ENTIDADES.SEGURIDAD.EstadoGrupo>())
                    {
                        <option value="@e.Nombre">@e.Nombre</option>
                    }
                </select>
                <button class="seg-btn-buscar" onclick="sgFiltrarGrupos()">BUSCAR</button>
            </div>
            <div class="data-table-wrap">
                <table class="data-table seg-table" id="tabla-seg-grupos">
                    <thead><tr><th style="width:40px">Id</th><th>NombreGrupo</th><th>Codigo</th><th>EstadoGrupoId</th><th>EstadoGrupo</th><th>Descripcion</th><th>Nombre_Alias</th></tr></thead>
                    <tbody>
                        @foreach (var g in ViewBag.Grupos as List<ENTIDADES.Grupo> ?? new List<ENTIDADES.Grupo>())
                        {
                            <tr onclick="sgSeleccionarGrupo(this, @g.Id)"
                                data-id="@g.Id" data-nombre="@g.NombreGrupo" data-codigo="@g.Codigo"
                                data-descripcion="@Html.Raw(g.Descripcion?.Replace("\"", "&quot;") ?? "")"
                                data-estado="@(g.EstadoGrupo?.Nombre ?? "")">
                                <td>@g.Id</td>
                                <td>@g.NombreGrupo</td>
                                <td>@g.Codigo</td>
                                <td>@g.EstadoGrupoId</td>
                                <td>@(g.EstadoGrupo?.Nombre ?? "—")</td>
                                <td>@g.Descripcion</td>
                                <td>@g.NombreGrupo</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="seg-botones-bar">
                <button class="seg-btn-accion seg-btn-agregar" onclick="abrirModalAgregarGrupo()">AGREGAR</button>
                <button class="seg-btn-accion seg-btn-eliminar2" onclick="sgEliminarGrupo()" id="btn-sg-grp-eliminar" disabled>ELIMINAR</button>
                <button class="seg-btn-accion seg-btn-modificar" onclick="abrirModalModificarGrupo()" id="btn-sg-grp-modificar" disabled>MODIFICAR</button>
                <button class="seg-back-float" onclick="ocultarSecciones()">✕</button>
            </div>
        </div>

        @* SUB: USUARIOS *@
        <div class="seg-seccion" id="seg-usuarios" style="display:none">
            <div class="seg-form-header">
                <div class="seg-form-titulo">FrescoMarket — GESTIONAR USUARIOS</div>
                <button class="seg-btn-refrescar" onclick="sgUsuariosRefrescar()" title="Refrescar">↺</button>
            </div>
            <div class="seg-filtros-bar">
                <span class="seg-filtros-lbl">FILTROS</span>
                <label class="seg-flbl">NOMBRE:</label>
                <input type="text" id="sg-usr-fnombre" class="seg-finput" oninput="sgFiltrarUsuarios()" />
                <label class="seg-flbl">GRUPO:</label>
                <select id="sg-usr-fgrupo" class="seg-fselect" onchange="sgFiltrarUsuarios()">
                    <option value="">Todos</option>
                    @foreach (var g in ViewBag.Grupos as List<ENTIDADES.Grupo> ?? new List<ENTIDADES.Grupo>())
                    {
                        <option value="@g.NombreGrupo">@g.NombreGrupo</option>
                    }
                </select>
                <label class="seg-flbl">ESTADO:</label>
                <select id="sg-usr-festado" class="seg-fselect" onchange="sgFiltrarUsuarios()">
                    <option value="">Todos</option>
                    @foreach (var e in ViewBag.EstadosUsuario as List<ENTIDADES.SEGURIDAD.EstadoUsuario> ?? new List<ENTIDADES.SEGURIDAD.EstadoUsuario>())
                    {
                        <option value="@e.Nombre">@e.Nombre</option>
                    }
                </select>
                <button class="seg-btn-buscar" onclick="sgFiltrarUsuarios()">BUSCAR</button>
            </div>
            <div class="data-table-wrap">
                <table class="data-table seg-table" id="tabla-seg-usuarios">
                    <thead><tr><th>NombreUsuario</th><th>Rol</th><th>Estado</th><th>FechaCreacion</th><th>UltimoAcceso</th><th>IntentosIngreso</th><th>Email</th></tr></thead>
                    <tbody>
                        @foreach (var u in ViewBag.Usuarios as List<ENTIDADES.Usuario> ?? new List<ENTIDADES.Usuario>())
                        {
                            <tr onclick="sgSeleccionarUsuario(this, @u.Id)"
                                data-id="@u.Id" data-nombre="@u.NombreUsuario" data-rol="@u.Rol"
                                data-grupos="@(u.Grupos != null ? string.Join(",", u.Grupos.Select(g => g.NombreGrupo)) : "")">
                                <td>@u.NombreUsuario</td>
                                <td>@u.Rol</td>
                                <td style="text-align:center">@(u.Estado ? "✓" : "✗")</td>
                                <td>@u.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(u.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td style="text-align:center">@u.IntentosIngreso</td>
                                <td>@(u.Email ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="seg-botones-bar">
                <button class="seg-btn-accion seg-btn-agregar" onclick="sgAgregarUsuario()">AGREGAR</button>
                <button class="seg-btn-accion seg-btn-eliminar2" onclick="sgEliminarUsuario()" id="btn-sg-usr-eliminar" disabled>ELIMINAR</button>
                <button class="seg-btn-accion seg-btn-modificar" onclick="sgModificarUsuario()" id="btn-sg-usr-modificar" disabled>MODIFICAR</button>
                <button class="seg-btn-accion seg-btn-resetear" onclick="sgResetearUsuario()" id="btn-sg-usr-resetear" disabled>RESETEAR</button>
                <form asp-controller="Usuario" asp-action="Eliminar" method="post" id="form-sg-usr-eliminar"><input type="hidden" name="id" id="sg-usr-del-id" /></form>
                <form asp-controller="Usuario" asp-action="ResetearClave" method="post" id="form-sg-usr-reset"><input type="hidden" name="id" id="sg-usr-reset-id" /></form>
                <button class="seg-back-float" onclick="ocultarSecciones()">✕</button>
            </div>
        </div>

        @* SUB: AUDITORÍA *@
        <div class="seg-seccion" id="seg-auditoria" style="display:none">
            <div class="seg-form-header"><div class="seg-form-titulo">FrescoMarket — AUDITORÍA DE SESIONES</div></div>
            <div class="auditoria-filtros">
                <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
                    <div class="panel-field" style="min-width:150px">
                        <label>USUARIO</label>
                        <select id="aud-usuario-sel" class="aud-select">
                            <option value="">— Todos —</option>
                            @foreach (var u in ViewBag.Usuarios as List<ENTIDADES.Usuario> ?? new List<ENTIDADES.Usuario>())
                            {
                                <option value="@u.Id">@u.NombreUsuario</option>
                            }
                        </select>
                    </div>
                    <div class="panel-field" style="min-width:130px"><label>DESDE</label><input type="date" id="aud-desde" class="aud-input" /></div>
                    <div class="panel-field" style="min-width:130px"><label>HASTA</label><input type="date" id="aud-hasta" class="aud-input" /></div>
                    <button class="btn-search" style="padding:5px 14px" onclick="auditoriaFiltrar()">FILTRAR</button>
                    <button class="btn-clear" style="padding:5px 10px" onclick="auditoriaLimpiar()">LIMPIAR</button>
                </div>
            </div>
            @{
                var sesiones = ViewBag.Sesiones as List<ENTIDADES.AuditoriaSesion> ?? new List<ENTIDADES.AuditoriaSesion>();
            }
            <div class="aud-resumen">
                <div class="aud-stat"><span class="aud-stat-num" id="aud-total-count">@sesiones.Count</span><span class="aud-stat-lbl">Total sesiones</span></div>
                <div class="aud-stat activa"><span class="aud-stat-num" id="aud-activa-count">@sesiones.Count(s => s.SesionActiva)</span><span class="aud-stat-lbl">Activas</span></div>
                <div class="aud-stat cerrada"><span class="aud-stat-num" id="aud-cerrada-count">@sesiones.Count(s => !s.SesionActiva)</span><span class="aud-stat-lbl">Cerradas</span></div>
            </div>
            <div class="data-table-wrap">
                <table class="data-table" id="tabla-auditoria">
                    <thead><tr><th>Usuario</th><th>Ingreso</th><th>Salida</th><th>IP</th><th>Dispositivo</th><th>Tipo</th><th>Estado</th></tr></thead>
                    <tbody id="aud-tbody">
                        @foreach (var a in sesiones)
                        {
                            <tr>
                                <td><strong>@a.NombreUsuario</strong></td>
                                <td>@a.FechaIngreso.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(a.FechaSalida?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td>@(a.DireccionIP == "::1" ? "127.0.0.1" : (a.DireccionIP?.StartsWith("::ffff:") == true ? a.DireccionIP.Substring(7) : a.DireccionIP ?? "—"))</td>
                                <td>@a.Dispositivo</td>
                                <td>@a.TipoSesion</td>
                                <td><span class="aud-badge @(a.SesionActiva ? "activa" : "cerrada")">@(a.SesionActiva ? "● Activa" : "○ Cerrada")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="seg-botones-bar"><button class="seg-back-float" onclick="ocultarSecciones()">✕</button></div>
        </div>

        @* SUB: BACKUP *@
        <div class="seg-seccion" id="seg-backup" style="display:none">
            <div class="seg-form-header"><div class="seg-form-titulo">FrescoMarket — BACKUP Y RESTAURACIÓN</div></div>
            <div class="backup-grid">
                <div class="backup-card">
                    <div class="backup-card-titulo">CREAR BACKUP</div>
                    <p style="font-size:11px;color:#7a5500;margin-bottom:10px;">Genera un archivo .bak de la base de datos.</p>
                    <button class="btn-form-save" id="btn-crear-backup" onclick="backupCrear()">CREAR BACKUP AHORA</button>
                    <div id="backup-status" style="margin-top:8px;font-size:11px;display:none;"></div>
                </div>
                <div class="backup-card">
                    <div class="backup-card-titulo">RESTAURAR / DESCARGAR</div>
                    <p style="font-size:11px;color:#7a5500;margin-bottom:6px;">Último backup: <span id="lbl-ultimo-backup">—</span></p>
                    <div class="form-field" style="margin-bottom:8px;">
                        <label>SELECCIONAR BACKUP:</label>
                        <select id="sel-backups" class="aud-select"><option value="">Cargando...</option></select>
                    </div>
                    <div style="display:flex;gap:6px;">
                        <button class="vt-btn vt-btn-detalle" style="flex:1;padding:5px 0" onclick="backupDescargar()">DESCARGAR</button>
                        <button class="vt-btn vt-btn-eliminar" style="flex:1;padding:5px 0" onclick="backupRestaurar()">RESTAURAR BD</button>
                    </div>
                    <div id="restore-status" style="margin-top:8px;font-size:11px;display:none;"></div>
                </div>
            </div>
            <div class="seg-botones-bar"><button class="seg-back-float" onclick="ocultarSecciones()">✕</button></div>
        </div>


        @* ── MODAL MODIFICAR USUARIO ── *@
        <div id="modal-mod-usuario" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
            background:rgba(0,0,0,0.55);z-index:2000;align-items:center;justify-content:center;">
            <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:420px;max-width:95vw;">
                <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;
                    display:flex;align-items:center;justify-content:space-between;">
                    <span style="font-size:13px;font-weight:700;color:#3a2500;">MODIFICAR USUARIO</span>
                    <button onclick="cerrarModalModUsuario()"
                            style="background:#8B6508;border:none;color:#f5d060;border-radius:50%;
                        width:22px;height:22px;cursor:pointer;font-weight:700;">
                        ✕
                    </button>
                </div>
                <div style="padding:16px;">
                    <div style="font-size:11px;color:#7a5500;margin-bottom:14px;background:#fff8dc;
                        border:1px solid #e8c840;border-radius:4px;padding:8px;">
                        Usuario: <strong id="mod-usr-nombre" style="color:#3a2500;"></strong>
                    </div>
                    <form asp-controller="Usuario" asp-action="Modificar" method="post">
                        <input type="hidden" name="Id" id="mod-usr-id" />
                        <input type="hidden" name="__panel" value="seguridad" />
                        <div class="form-field">
                            <label>EMAIL:</label>
                            <input type="email" name="Email" id="mod-usr-email"
                                   class="seg-finput" style="width:100%"
                                   placeholder="correo@email.com" />
                        </div>
                        <div class="form-field">
                            <label>ESTADO:</label>
                            <select name="Estado" id="mod-usr-estado"
                                    class="seg-fselect" style="width:100%">
                                <option value="true">Activo ✓</option>
                                <option value="false">Inactivo ✗</option>
                            </select>
                        </div>
                        <div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end;">
                            <button type="button" onclick="cerrarModalModUsuario()"
                                    class="btn-cancelar" style="padding:5px 16px;font-size:11px;">
                                CANCELAR
                            </button>
                            <button type="submit" class="btn-form-save"
                                    style="width:auto;padding:5px 20px;">
                                GUARDAR
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>


        @* ── LOG DE ACTIVIDAD — dentro del panel seguridad ── *@
        @{
            var logActividad = ViewBag.LogActividad as List<ENTIDADES.LogActividad> ?? new List<ENTIDADES.LogActividad>();
        }
        <div style="margin-top:18px;background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:14px;box-shadow:0 2px 8px rgba(184,134,11,0.1);">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;border-bottom:1px solid #f0d080;padding-bottom:8px;flex-wrap:wrap;">
                <span style="font-size:16px;">📋</span>
                <span style="font-size:11px;font-weight:800;color:#5a3e00;letter-spacing:0.5px;">LOG DE ACTIVIDAD DEL SISTEMA</span>
                <span style="margin-left:auto;background:#b8860b;color:#fff;border-radius:12px;padding:2px 10px;font-size:10px;font-weight:700;">
                    @logActividad.Count registros
                </span>
                <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                    <input type="text" id="log-buscar" placeholder="Buscar usuario o acción..."
                           oninput="logFiltrar(this.value)"
                           style="border:1px solid #c8a000;border-radius:3px;padding:4px 8px;font-size:11px;background:#fffef0;width:200px;" />
                    <select id="log-filtro-accion" onchange="logFiltrar(document.getElementById('log-buscar').value)"
                            style="border:1px solid #c8a000;border-radius:3px;padding:4px 6px;font-size:11px;background:#fffef0;">
                        <option value="">Todas las acciones</option>
                        <option value="venta">Ventas</option>
                        <option value="compra">Compras</option>
                        <option value="cliente">Clientes</option>
                        <option value="producto">Productos</option>
                        <option value="proveedor">Proveedores</option>
                        <option value="catálogo">Catálogo</option>
                        <option value="promoción">Promociones</option>
                    </select>
                    <button class="btn-clear" style="padding:4px 10px;font-size:10px;" onclick="logLimpiar()">LIMPIAR</button>
                </div>
            </div>
            @if (!logActividad.Any())
            {
                <div style="text-align:center;color:#aaa;font-size:12px;padding:20px 0;">
                    No hay actividad registrada aún.
                </div>
            }
            else
            {
                <div style="max-height:340px;overflow-y:auto;">
                    <table class="data-table" id="tabla-log">
                        <thead>
                            <tr>
                                <th style="width:130px;">Fecha</th>
                                <th style="width:120px;">Usuario</th>
                                <th style="width:160px;">Acción</th>
                                <th>Detalle</th>
                                <th style="width:110px;">IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in logActividad)
                            {
                                var colorAccion = log.Accion.Contains("Eliminó") ? "#c0392b"
                                    : log.Accion.Contains("Modificó") ? "#e67e22"
                                    : log.Accion.Contains("Nueva") || log.Accion.Contains("Nuevo") ? "#27ae60"
                                    : log.Accion.Contains("Aprobó") ? "#2980b9"
                                    : log.Accion.Contains("Rechazó") ? "#8e44ad"
                                    : "#b8860b";
                                var iconoAccion = log.Accion.Contains("Eliminó") ? "🗑️"
                                    : log.Accion.Contains("Modificó") ? "✏️"
                                    : log.Accion.Contains("Venta") ? "💰"
                                    : log.Accion.Contains("Compra") ? "📦"
                                    : log.Accion.Contains("Cliente") ? "👤"
                                    : log.Accion.Contains("Producto") ? "🏷️"
                                    : log.Accion.Contains("Proveedor") ? "🏭"
                                    : log.Accion.Contains("Catálogo") ? "📋"
                                    : log.Accion.Contains("Promoción") ? "🎯"
                                    : "📝";
                                <tr data-usuario="@log.UsuarioNombre.ToLower()" data-accion="@log.Accion.ToLower()">
                                    <td style="font-size:10px;color:#7a5500;">@log.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="font-weight:700;color:#3a2500;font-size:11px;">@log.UsuarioNombre</td>
                                    <td>
                                        <span style="display:inline-flex;align-items:center;gap:4px;background:@(colorAccion)18;
                                            color:@colorAccion;border-radius:4px;padding:2px 8px;font-size:10px;font-weight:700;">
                                            @iconoAccion @log.Accion
                                        </span>
                                    </td>
                                    <td style="font-size:11px;color:#5a3e00;">@(log.Detalle ?? "—")</td>
                                    <td style="font-size:10px;color:#aaa;">
                                        @(log.IP == "::1" ? "127.0.0.1" : (log.IP?.StartsWith("::ffff:") == true ? log.IP.Substring(7) : log.IP ?? "—"))
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>

