        }
        function cerrarModalRegistro() { document.getElementById('modal-registro-usuario').style.display = 'none'; }

        // ── Modal informe ──
        function abrirModalInforme(tipo) {
        _infTipo = tipo;
        document.getElementById('modal-inf-titulo').textContent = 'GENERAR INFORME DE ' + (tipo === 'ventas' ? 'VENTAS' : 'COMPRAS');
        var hoy = new Date(), hace30 = new Date();
        hace30.setDate(hoy.getDate() - 30);
        function fmt(d) { return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); }
        document.getElementById('inf-desde').value = fmt(hace30);
        document.getElementById('inf-hasta').value = fmt(hoy);
        document.getElementById('inf-resumen').style.display = 'none';
        document.getElementById('inf-chart-loading').style.display = 'block';
        document.getElementById('inf-chart-empty').style.display = 'none';
        if (_infChart) { _infChart.destroy(); _infChart = null; }
        document.getElementById('modal-informe').style.display = 'flex';
        setTimeout(informeActualizarGrafico, 100);
        }
        function cerrarModalInforme() {
        document.getElementById('modal-informe').style.display = 'none';
        if (_infChart) { _infChart.destroy(); _infChart = null; }
        }
        function informeActualizarGrafico() {
        var desde = document.getElementById('inf-desde').value;
        var hasta = document.getElementById('inf-hasta').value;
        if (!desde || !hasta) { alert('Seleccione las fechas.'); return; }
        document.getElementById('inf-chart-loading').textContent = 'Cargando datos...';
        document.getElementById('inf-chart-loading').style.display = 'block';
        document.getElementById('inf-chart-empty').style.display = 'none';
        var tableId = _infTipo === 'ventas' ? 'tabla-ventas' : 'tabla-compras';
        var rows = Array.from(document.querySelectorAll('#' + tableId + ' tbody tr'));
        var diasMap = {}, totalGen = 0, cant = 0;
        rows.forEach(function (r) {
        if (!r.dataset.fecha) return;
        var partes = r.dataset.fecha.split(' ')[0].split('/');
        var fecha = partes[2] + '-' + partes[1] + '-' + partes[0];
        if (fecha < desde || fecha > hasta) return;
        var total = parseFloat(r.dataset.total.replace(',', '')) || 0;
        var label = partes[0] + '/' + partes[1];
        if (!diasMap[label]) diasMap[label] = 0;
        diasMap[label] += total;
        totalGen += total; cant++;
        });
        document.getElementById('inf-chart-loading').style.display = 'none';
        var labels = Object.keys(diasMap).sort();
        var values = labels.map(k => diasMap[k]);
        if (!labels.length) {
        document.getElementById('inf-chart-empty').style.display = 'block';
        document.getElementById('inf-resumen').style.display = 'none';
        return;
        }
        if (_infChart) { _infChart.destroy(); _infChart = null; }
        var ctx = document.getElementById('inf-chart').getContext('2d');
        _infChart = new Chart(ctx, {
        type: 'bar',
        data: { labels: labels, datasets: [{ label: _infTipo === 'ventas' ? 'Ventas Diarias ($)' : 'Compras Diarias ($)', data: values, backgroundColor: 'rgba(70,130,180,0.75)', borderColor: 'rgba(70,130,180,1)', borderWidth: 1, borderRadius: 3 }] },
        options: { responsive: true, plugins: { legend: { display: false }, tooltip: { callbacks: { label: function (ctx) { return '$' + ctx.parsed.y.toFixed(2); } } } }, scales: { y: { beginAtZero: true, ticks: { callback: function (v) { return '$' + v.toLocaleString(); } } } } }
        });
        document.getElementById('inf-total').textContent = '$' + totalGen.toFixed(2);
        document.getElementById('inf-cant').textContent = cant;
        document.getElementById('inf-prom').textContent = cant > 0 ? '$' + (totalGen / cant).toFixed(2) : '$0';
        document.getElementById('inf-resumen').style.display = 'block';
        }
        function informeDescargarPDF() {
        var desde = document.getElementById('inf-desde').value;
        var hasta = document.getElementById('inf-hasta').value;
        if (!desde || !hasta) { alert('Seleccione las fechas primero.'); return; }
        var url = (_infTipo === 'ventas' ? '/Reporte/GenerarReporteVentas' : '/Reporte/GenerarReporteCompras') + '?desde=' + desde + '&hasta=' + hasta;
        window.open(url, '_blank');
        }

        // ── MODAL APROBAR CATÁLOGO ──
        function abrirModalAprobar(catalogoId) {
        fetch('/Catalogo/ObtenerInfoAprobacion?id=' + catalogoId)
        .then(r => r.json())
        .then(function (data) {
        if (!data.ok) { alert('Error al obtener info del producto.'); return; }
        document.getElementById('apr-id').value = data.id;
        document.getElementById('apr-nombre-prod').textContent = data.nombreProducto;
        document.getElementById('apr-proveedor').textContent = data.proveedorNombre;
        document.getElementById('apr-precio-sug').textContent = parseFloat(data.precio).toFixed(2);
        document.getElementById('apr-precio').value = parseFloat(data.precio).toFixed(2);
        document.getElementById('apr-cantidad').value = 1;
        document.getElementById('apr-factura').value = '';
        document.getElementById('modal-aprobar-cat').style.display = 'flex';
        })
        .catch(function () { alert('Error de conexión.'); });
        }
        function cerrarModalAprobar() { document.getElementById('modal-aprobar-cat').style.display = 'none'; }
        function confirmarAprobacion() {
        var cantidad = document.getElementById('apr-cantidad').value;
        var precio = document.getElementById('apr-precio').value;
        var factura = document.getElementById('apr-factura').value.trim();
        if (!cantidad || parseInt(cantidad) <= 0) { alert('Ingrese una cantidad válida.'); return; }
        if (!precio || parseFloat(precio) <= 0) { alert('Ingrese un precio válido.'); return; }
        if (!factura) { alert('Ingrese el número de factura.'); return; }
        document.getElementById('apr-cantidad-h').value = cantidad;
        document.getElementById('apr-precio-h').value = precio;
        document.getElementById('apr-factura-h').value = factura;
        document.getElementById('form-aprobar-cat').submit();
        }
        document.getElementById('modal-aprobar-cat').addEventListener('click', function (e) {
        if (e.target === this) cerrarModalAprobar();
        });

        // ── ASIGNAR PRODUCTOS A PROVEEDOR ──
        var asigProductosData = [];
        function abrirModalAsignarProductos() {
        if (!proveedorSeleccionadoId) { alert('Seleccione un proveedor.'); return; }
        var row = document.querySelector('#tabla-proveedores tbody tr.selected');
        var razon = row ? row.dataset.razon : 'Proveedor';
        document.getElementById('modal-asig-titulo').textContent = 'ASIGNAR PRODUCTOS — ' + razon;
        document.getElementById('asig-loading').style.display = 'block';
        document.getElementById('tabla-asig-prod').style.display = 'none';
        document.getElementById('asig-buscar').value = '';
        document.getElementById('modal-asignar-prod').style.display = 'flex';
        fetch('/Proveedor/ObtenerProductosProveedor?proveedorId=' + proveedorSeleccionadoId)
        .then(r => r.json())
        .then(function (data) {
        asigProductosData = data;
        document.getElementById('asig-loading').style.display = 'none';
        document.getElementById('tabla-asig-prod').style.display = '';
        asigRenderTabla(data);
        })
        .catch(function () { document.getElementById('asig-loading').textContent = 'Error al cargar productos.'; });
        }
        function cerrarModalAsignarProductos() { document.getElementById('modal-asignar-prod').style.display = 'none'; }
        function asigRenderTabla(productos) {
        var tbody = document.getElementById('asig-tbody');
        tbody.innerHTML = '';
        if (!productos.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#aaa;padding:14px;">No hay productos disponibles.</td></tr>';
        asigActualizarContador(); return;
        }
        productos.forEach(function (p) {
        var tr = document.createElement('tr');
        tr.dataset.id = p.id;
        tr.dataset.nombre = p.nombre.toLowerCase();
        tr.dataset.codigo = p.codigo.toLowerCase();
        tr.innerHTML = '<td style="text-align:center;"><input type="checkbox" id="chk-prod-' + p.id + '" ' + (p.asignado ? 'checked' : '') + ' onchange="asigActualizarContador()" style="width:16px;height:16px;cursor:pointer;" /></td>' +
        '<td><label for="chk-prod-' + p.id + '" style="cursor:pointer;">' + p.nombre + '</label></td>' +
        '<td>' + p.codigo + '</td><td>$' + parseFloat(p.precio).toFixed(2) + '</td><td>' + p.stock + '</td>';
        tbody.appendChild(tr);
        });
        asigActualizarContador();
        }
        function asigFiltrar(val) {
        var q = val.toLowerCase().trim();
        document.querySelectorAll('#asig-tbody tr').forEach(function (row) {
        if (!row.dataset.nombre) return;
        row.style.display = (!q || row.dataset.nombre.includes(q) || row.dataset.codigo.includes(q)) ? '' : 'none';
        });
        }
        function asigActualizarContador() {
        var total = document.querySelectorAll('#asig-tbody input[type="checkbox"]:checked').length;
        document.getElementById('asig-contador').textContent = total + ' producto(s) seleccionado(s)';
        }
        function guardarAsignacionProductos() {
        var ids = Array.from(document.querySelectorAll('#asig-tbody input[type="checkbox"]:checked'))
        .map(function (chk) { return parseInt(chk.id.replace('chk-prod-', '')); });
        fetch('/Proveedor/GuardarProductosProveedor?proveedorId=' + proveedorSeleccionadoId, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(ids)
        })
        .then(r => r.json())
        .then(function (data) {
        if (data.ok) {
        cerrarModalAsignarProductos();
        var t = document.createElement('div');
        t.className = 'toast-msg toast-success';
        t.textContent = '✓ ' + data.mensaje;
        document.body.appendChild(t);
        setTimeout(function () { t.classList.add('toast-hide'); setTimeout(function () { t.remove(); }, 400); }, 3000);
        } else { alert('Error: ' + data.error); }
        })
        .catch(function () { alert('Error de conexión al guardar.'); });
        }
        document.getElementById('modal-asignar-prod').addEventListener('click', function (e) {
        if (e.target === this) cerrarModalAsignarProductos();
        });

        // ── CATÁLOGO DEL PROVEEDOR (ADMIN) ──
        function abrirModalCatalogo() {
        if (!proveedorSeleccionadoId) { alert('Seleccione un proveedor.'); return; }
        var row = document.querySelector('#tabla-proveedores tbody tr.selected');
        var razon = row ? row.dataset.razon : 'Proveedor';
        document.getElementById('modal-cat-titulo').textContent = 'CATÁLOGO — ' + razon;
        document.getElementById('cat-loading').style.display = 'block';
        document.getElementById('tabla-cat-admin').style.display = 'none';
        document.getElementById('cat-empty').style.display = 'none';
        document.getElementById('modal-catalogo-prov').style.display = 'flex';
        fetch('/Catalogo/ObtenerCatalogoProveedor?proveedorId=' + proveedorSeleccionadoId)
        .then(r => r.json())
        .then(function (data) {
        document.getElementById('cat-loading').style.display = 'none';
        if (!data.length) { document.getElementById('cat-empty').style.display = 'block'; return; }
        document.getElementById('tabla-cat-admin').style.display = '';
        var tbody = document.getElementById('cat-admin-tbody');
        tbody.innerHTML = '';
        data.forEach(function (item) {
        var colorEstado = item.estado === 'Aprobado' ? '#27ae60' : item.estado === 'Rechazado' ? '#c0392b' : '#e67e22';
        var acciones = item.estado === 'Pendiente'
        ? '<button onclick="abrirModalAprobar(' + item.id + ')" class="btn-form-update" style="padding:3px 10px;font-size:10px;margin-right:4px;">APROBAR</button>' +
        '<form action="/Catalogo/Rechazar" method="post" style="display:inline"><input type="hidden" name="id" value="' + item.id + '"/><input type="hidden" name="__panel" value="proveedores"/><button type="submit" class="btn-form-del" style="padding:3px 10px;font-size:10px;">RECHAZAR</button></form>'
        : '<span style="font-size:10px;color:' + colorEstado + ';font-weight:700;">' + item.estado + '</span>';
        tbody.innerHTML += '<tr><td>' + item.nombreProducto + '</td><td>$' + parseFloat(item.precio).toFixed(2) + '</td><td>' + (item.descripcion || '—') + '</td><td>' + item.fecha + '</td><td><span style="font-weight:700;color:' + colorEstado + ';">' + item.estado + '</span></td><td>' + acciones + '</td></tr>';
        });
        })
        .catch(function () { document.getElementById('cat-loading').textContent = 'Error al cargar el catálogo.'; });
        }
        function cerrarModalCatalogo() { document.getElementById('modal-catalogo-prov').style.display = 'none'; }
        document.getElementById('modal-catalogo-prov').addEventListener('click', function (e) {
        if (e.target === this) cerrarModalCatalogo();
        });

        // ── PROMOCIONES ──
        document.getElementById('promo-tipo').addEventListener('change', function () {
        document.getElementById('promo-valor-lbl').textContent = this.value === 'Porcentaje' ? 'VALOR (%):' : 'VALOR ($):';
        promoActualizarPreview();
        });
        document.getElementById('promo-valor').addEventListener('input', promoActualizarPreview);
        document.getElementById('promo-producto').addEventListener('change', promoActualizarPreview);

        function promoActualizarPreview() {
        var productoSel = document.getElementById('promo-producto');
        var tipo = document.getElementById('promo-tipo').value;
        var valor = parseFloat(document.getElementById('promo-valor').value) || 0;
        var preview = document.getElementById('promo-preview');
        if (!productoSel.value || valor <= 0) { preview.style.display = 'none'; return; }
        var opt = productoSel.options[productoSel.selectedIndex];
        var precio = parseFloat(opt.dataset.precio) || 0;
        if (precio <= 0) { preview.style.display = 'none'; return; }
        var precioFinal = tipo === 'Porcentaje' ? precio - (precio * valor / 100) : precio - valor;
        if (precioFinal < 0) precioFinal = 0;
        preview.style.display = 'block';
        preview.innerHTML = '💰 Precio original: $' + precio.toFixed(2) + '<br>🏷️ Precio con descuento: <strong>$' + precioFinal.toFixed(2) + '</strong>';
        }

        function promoCrear() {
        var productoId = document.getElementById('promo-producto').value;
        var tipo = document.getElementById('promo-tipo').value;
        var valor = document.getElementById('promo-valor').value;
        var fechaFin = document.getElementById('promo-fecha-fin').value;
        if (!productoId) { alert('Seleccione un producto.'); return; }
        if (!valor || parseFloat(valor) <= 0) { alert('Ingrese un valor de descuento válido.'); return; }
        if (tipo === 'Porcentaje' && parseFloat(valor) > 100) { alert('El porcentaje no puede ser mayor a 100.'); return; }
        if (!fechaFin) { alert('Ingrese la fecha de fin de la promoción.'); return; }
        if (new Date(fechaFin) <= new Date()) { alert('La fecha de fin debe ser futura.'); return; }
        document.getElementById('h-promo-producto').value = productoId;
        document.getElementById('h-promo-tipo').value = tipo;
        document.getElementById('h-promo-valor').value = valor;
        document.getElementById('h-promo-fecha-fin').value = fechaFin;
        document.getElementById('h-promo-desc').value = document.getElementById('promo-desc').value;
        document.getElementById('form-promo-crear').submit();
        }

        function promoFiltrar() {
        var filtro = document.getElementById('promo-filtro-estado').value;
        document.querySelectorAll('#promo-tbody tr').forEach(function (row) {
        if (!row.dataset.vigente) return;
        if (!filtro) { row.style.display = ''; return; }
        if (filtro === 'vigente') row.style.display = row.dataset.vigente === 'true' ? '' : 'none';
        if (filtro === 'inactiva') row.style.display = row.dataset.vigente === 'false' ? '' : 'none';
        });
        }

        function promoCargarTabla() {
        fetch('/Promocion/ObtenerTodas')
        .then(r => r.json())
        .then(function (data) {
        var tbody = document.getElementById('promo-tbody');
        tbody.innerHTML = '';
        if (!data.length) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#aaa;padding:14px;">No hay promociones registradas.</td></tr>';
        return;
        }
        data.forEach(function (p) {
        var colorEstado = p.vigente ? '#27ae60' : '#c0392b';
        var estadoTexto = p.vigente ? '● Vigente' : (p.activa ? '○ Vencida' : '○ Inactiva');
        var descuento = p.tipoDescuento === 'Porcentaje' ? p.valorDescuento + '%' : '$' + parseFloat(p.valorDescuento).toFixed(2);
        var acciones = p.vigente
        ? '<form action="/Promocion/Desactivar" method="post" style="display:inline"><input type="hidden" name="id" value="' + p.id + '"/><input type="hidden" name="__panel" value="promociones"/><button type="submit" class="btn-form-del" style="padding:2px 8px;font-size:10px;margin-right:3px;">DESACTIVAR</button></form>' +
        '<form action="/Promocion/Eliminar" method="post" style="display:inline"><input type="hidden" name="id" value="' + p.id + '"/><input type="hidden" name="__panel" value="promociones"/><button type="submit" class="btn-form-del" style="padding:2px 8px;font-size:10px;">ELIMINAR</button></form>'
        : '<form action="/Promocion/Eliminar" method="post" style="display:inline"><input type="hidden" name="id" value="' + p.id + '"/><input type="hidden" name="__panel" value="promociones"/><button type="submit" class="btn-form-del" style="padding:2px 8px;font-size:10px;">ELIMINAR</button></form>';
        var tr = document.createElement('tr');
        tr.dataset.vigente = p.vigente ? 'true' : 'false';
        tr.innerHTML = '<td>' + p.productoNombre + '</td><td style="font-weight:700;color:#2980b9;">' + descuento + '</td><td>' + (p.descripcion || '—') + '</td><td>' + p.fechaFin + '</td><td><span style="font-weight:700;color:' + colorEstado + ';">' + estadoTexto + '</span></td><td>' + acciones + '</td>';
        tbody.appendChild(tr);
        });
        })
        .catch(function () {
        document.getElementById('promo-tbody').innerHTML = '<tr><td colspan="6" style="text-align:center;color:#c0392b;padding:14px;">Error al cargar promociones.</td></tr>';
        });
        }

        var _originalShowPanel = window.showPanel;
        window.showPanel = function (name, btn) {
        _originalShowPanel(name, btn);
        if (name === 'promociones') promoCargarTabla();
        };

        // ── LOG DE ACTIVIDAD ──
        function logFiltrar(busqueda) {
        var q = (busqueda || '').toLowerCase();
        var filtroAccion = document.getElementById('log-filtro-accion').value.toLowerCase();
        document.querySelectorAll('#tabla-log tbody tr').forEach(function (row) {
        var usuario = (row.dataset.usuario || '');
        var accion = (row.dataset.accion || '');
        var matchBusqueda = !q || usuario.includes(q) || accion.includes(q);
        var matchAccion = !filtroAccion || accion.includes(filtroAccion);
        row.style.display = (matchBusqueda && matchAccion) ? '' : 'none';
        });
        }
        function logLimpiar() {
        document.getElementById('log-buscar').value = '';
        document.getElementById('log-filtro-accion').value = '';
        logFiltrar('');
        }

        // ── RELOJ EN VIVO ──
        function dashActualizarReloj() {
        var ahora = new Date();
        var hora = String(ahora.getHours()).padStart(2, '0') + ':' + String(ahora.getMinutes()).padStart(2, '0') + ':' + String(ahora.getSeconds()).padStart(2, '0');
        var dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
        var meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
        var fecha = dias[ahora.getDay()] + ', ' + ahora.getDate() + ' de ' + meses[ahora.getMonth()] + ' de ' + ahora.getFullYear();
        var elHora = document.getElementById('dash-hora');
        var elFecha = document.getElementById('dash-fecha');
        if (elHora) elHora.textContent = hora;
        if (elFecha) elFecha.textContent = fecha;
        }
        dashActualizarReloj();
        setInterval(dashActualizarReloj, 1000);
    </script>
}