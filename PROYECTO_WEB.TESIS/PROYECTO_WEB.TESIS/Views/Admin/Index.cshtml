@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // ── Restaurar panel activo tras POST ──
        (function () {
        var panel = '@(TempData["ActivePanel"] ?? "inicio")';
        if (panel && panel !== 'inicio') {
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        var el = document.getElementById('panel-' + panel);
        if (el) el.classList.add('active');
        document.querySelectorAll('.nav-btn').forEach(function (btn) {
        if (btn.getAttribute('onclick') && btn.getAttribute('onclick').includes("'" + panel + "'"))
        btn.classList.add('active');
        });
        }
        })();

        var _infTipo = 'ventas';
        var _infChart = null;

        // ── ASIGNAR USUARIO DEFAULT — CLIENTE ──
        function clienteAsignarUsuario() {
        if (!clienteSeleccionadoId) return;
        var row = document.querySelector('#tabla-clientes tbody tr.selected');
        var tieneUsuario = row?.dataset.tieneUsuario === 'si';

        if (tieneUsuario) {
        alert('Este cliente ya tiene un usuario asignado.');
        return;
        }

        var doc = row?.dataset.doc || '';
        if (!confirm('¿Asignar usuario automático a este cliente?\n\n' +
        'Se creará el usuario: cliente_' + doc + '\n' +
        'Con contraseña temporal: Cliente_' + doc + '!\n\n' +
        'El cliente deberá cambiarla al ingresar.')) return;

        document.getElementById('h-cli-asignar-id').value = clienteSeleccionadoId;
        document.getElementById('form-cli-asignar-usuario').submit();
        }

