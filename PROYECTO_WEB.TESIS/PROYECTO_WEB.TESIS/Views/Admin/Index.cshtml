        // ── Modal registro usuario ──
        function abrirModalRegistroUsuario(tipo) {
        document.getElementById('reg-tipo-usuario').value = tipo;
        document.getElementById('reg-campos-cliente').style.display = tipo === 'Cliente' ? '' : 'none';
        document.getElementById('reg-campos-proveedor').style.display = tipo === 'Proveedor' ? '' : 'none';
        document.getElementById('reg-titulo-datos').textContent = 'DATOS DEL ' + tipo.toUpperCase();
        document.getElementById('modal-reg-titulo').textContent = 'REGISTRAR ' + tipo.toUpperCase();
