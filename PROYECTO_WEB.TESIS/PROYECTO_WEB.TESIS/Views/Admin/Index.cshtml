@* Views/Admin/Index.cshtml — con todos los fixes *@
@{
    ViewData["Title"] = "Panel Administrador";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@{
    var productosVencer = ViewBag.ProductosProximosVencer as List<ENTIDADES.Producto> ?? new List<ENTIDADES.Producto>();
    var actividadReciente = ViewBag.ActividadReciente as List<(DateTime Fecha, string Icono, string Descripcion, string Color)> ?? new List<(DateTime, string, string, string)>();
    int ventasSemAct = ViewBag.VentasSemanaActual ?? 0;
    int ventasSemPas = ViewBag.VentasSemanaPasada ?? 0;
    int comprasSemAct = ViewBag.ComprasSemanaActual ?? 0;
    int comprasSemPas = ViewBag.ComprasSemanaPasada ?? 0;
}

@* ══════════════════════════════════════════════
   PANEL: INICIO / DASHBOARD
   ══════════════════════════════════════════════ *@
<div class="panel active" id="panel-inicio">
    <div class="panel-header">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0">
            <path d="M2 9L9 2l7 7" stroke="#3a2500" stroke-width="1.3" fill="none" stroke-linecap="round" />
            <rect x="5" y="9" width="8" height="7" rx="1" fill="#3a2500" />
        </svg>
        <h3>INICIO — PANEL DE INFORMACIÓN</h3>
    </div>
    <div class="panel-full" style="padding:18px;">

        <div style="background:linear-gradient(135deg,#b8860b 0%,#d4a017 60%,#f5d060 100%);
            border-radius:10px;padding:20px 24px;display:flex;align-items:center;
            justify-content:space-between;margin-bottom:18px;
            box-shadow:0 4px 15px rgba(184,134,11,0.3);flex-wrap:wrap;gap:12px;">
            <div style="display:flex;align-items:center;gap:16px;">
                <div style="width:60px;height:60px;background:#fff;border-radius:50%;
                    display:flex;align-items:center;justify-content:center;
                    box-shadow:0 2px 8px rgba(0,0,0,0.15);">
                    <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                        <circle cx="18" cy="18" r="17" fill="#d4a017" />
                        <path d="M8 22l5-8 4 5 3-4 5 7H8z" fill="#fff" />
                        <circle cx="24" cy="12" r="3" fill="#fff" />
                    </svg>
                </div>
                <div>
                    <div style="font-size:22px;font-weight:800;color:#3a2500;letter-spacing:1px;">🛒 FrescoMarket</div>
                    <div style="font-size:11px;color:#5a3e00;font-weight:600;margin-top:2px;">Sistema de Gestión de Minimarket</div>
                    <div style="font-size:10px;color:#7a5500;margin-top:1px;">Versión 1.0.0</div>
                </div>
            </div>
            <div style="text-align:right;">
                <div id="dash-hora" style="font-size:28px;font-weight:800;color:#3a2500;letter-spacing:2px;font-family:'Courier New',monospace;"></div>
                <div id="dash-fecha" style="font-size:12px;color:#5a3e00;font-weight:600;margin-top:2px;"></div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:18px;">
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(184,134,11,0.1);transition:transform 0.15s;"
                 onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                <div style="font-size:28px;margin-bottom:6px;">👥</div>
                <div style="font-size:26px;font-weight:800;color:#b8860b;">@(ViewBag.CantClientes ?? 0)</div>
                <div style="font-size:10px;font-weight:700;color:#7a5500;letter-spacing:0.5px;margin-top:4px;">CLIENTES</div>
            </div>
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(184,134,11,0.1);transition:transform 0.15s;"
                 onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                <div style="font-size:28px;margin-bottom:6px;">🔐</div>
                <div style="font-size:26px;font-weight:800;color:#b8860b;">@(ViewBag.UsuariosActivos ?? 0)</div>
                <div style="font-size:10px;font-weight:700;color:#7a5500;letter-spacing:0.5px;margin-top:4px;">USUARIOS ACTIVOS</div>
            </div>
            <div style="background:#fff;border:1.5px solid @((int)(ViewBag.OfertasPendientes ?? 0) > 0 ? "#e67e22" : "#e8c840");border-radius:8px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(184,134,11,0.1);transition:transform 0.15s;"
                 onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                <div style="font-size:28px;margin-bottom:6px;">📋</div>
                <div style="font-size:26px;font-weight:800;color:@((int)(ViewBag.OfertasPendientes ?? 0) > 0 ? "#e67e22" : "#b8860b");">@(ViewBag.OfertasPendientes ?? 0)</div>
                <div style="font-size:10px;font-weight:700;color:#7a5500;letter-spacing:0.5px;margin-top:4px;">OFERTAS PENDIENTES</div>
            </div>
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(184,134,11,0.1);transition:transform 0.15s;"
                 onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                <div style="font-size:28px;margin-bottom:6px;">💰</div>
                <div style="font-size:26px;font-weight:800;color:#27ae60;">@(ViewBag.VentasHoy ?? 0)</div>
                <div style="font-size:10px;font-weight:700;color:#7a5500;letter-spacing:0.5px;margin-top:4px;">VENTAS HOY</div>
            </div>
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:16px;text-align:center;box-shadow:0 2px 8px rgba(184,134,11,0.1);transition:transform 0.15s;"
                 onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                <div style="font-size:28px;margin-bottom:6px;">📦</div>
                <div style="font-size:26px;font-weight:800;color:#2980b9;">@(ViewBag.ComprasHoy ?? 0)</div>
                <div style="font-size:10px;font-weight:700;color:#7a5500;letter-spacing:0.5px;margin-top:4px;">COMPRAS HOY</div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px;">
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:14px;box-shadow:0 2px 8px rgba(184,134,11,0.1);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;border-bottom:1px solid #f0d080;padding-bottom:8px;">
                    <span style="font-size:16px;">📈</span>
                    <span style="font-size:11px;font-weight:800;color:#5a3e00;letter-spacing:0.5px;">VENTAS — COMPARATIVA SEMANAL</span>
                </div>
                <div style="display:flex;gap:12px;align-items:center;justify-content:space-around;">
                    <div style="text-align:center;">
                        <div style="font-size:10px;color:#7a5500;font-weight:700;margin-bottom:4px;">ESTA SEMANA</div>
                        <div style="font-size:28px;font-weight:800;color:#27ae60;">@ventasSemAct</div>
                    </div>
                    <div style="font-size:20px;color:#ccc;">vs</div>
                    <div style="text-align:center;">
                        <div style="font-size:10px;color:#7a5500;font-weight:700;margin-bottom:4px;">SEMANA PASADA</div>
                        <div style="font-size:28px;font-weight:800;color:#95a5a6;">@ventasSemPas</div>
                    </div>
                    <div style="text-align:center;">
                        @{
                            var diffVentas = ventasSemAct - ventasSemPas;
                            var colorVentas = diffVentas >= 0 ? "#27ae60" : "#c0392b";
                            var iconoVentas = diffVentas > 0 ? "↑" : diffVentas < 0 ? "↓" : "=";
                        }
                        <div style="font-size:10px;color:#7a5500;font-weight:700;margin-bottom:4px;">DIFERENCIA</div>
                        <div style="font-size:22px;font-weight:800;color:@colorVentas;">@iconoVentas @Math.Abs(diffVentas)</div>
                    </div>
                </div>
            </div>
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:14px;box-shadow:0 2px 8px rgba(184,134,11,0.1);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;border-bottom:1px solid #f0d080;padding-bottom:8px;">
                    <span style="font-size:16px;">📉</span>
                    <span style="font-size:11px;font-weight:800;color:#5a3e00;letter-spacing:0.5px;">COMPRAS — COMPARATIVA SEMANAL</span>
                </div>
                <div style="display:flex;gap:12px;align-items:center;justify-content:space-around;">
                    <div style="text-align:center;">
                        <div style="font-size:10px;color:#7a5500;font-weight:700;margin-bottom:4px;">ESTA SEMANA</div>
                        <div style="font-size:28px;font-weight:800;color:#2980b9;">@comprasSemAct</div>
                    </div>
                    <div style="font-size:20px;color:#ccc;">vs</div>
                    <div style="text-align:center;">
                        <div style="font-size:10px;color:#7a5500;font-weight:700;margin-bottom:4px;">SEMANA PASADA</div>
                        <div style="font-size:28px;font-weight:800;color:#95a5a6;">@comprasSemPas</div>
                    </div>
                    <div style="text-align:center;">
                        @{
                            var diffCompras = comprasSemAct - comprasSemPas;
                            var colorCompras = diffCompras >= 0 ? "#27ae60" : "#c0392b";
                            var iconoCompras = diffCompras > 0 ? "↑" : diffCompras < 0 ? "↓" : "=";
                        }
                        <div style="font-size:10px;color:#7a5500;font-weight:700;margin-bottom:4px;">DIFERENCIA</div>
                        <div style="font-size:22px;font-weight:800;color:@colorCompras;">@iconoCompras @Math.Abs(diffCompras)</div>
                    </div>
                </div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:14px;box-shadow:0 2px 8px rgba(184,134,11,0.1);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;border-bottom:1px solid #f0d080;padding-bottom:8px;">
                    <span style="font-size:16px;">🕐</span>
                    <span style="font-size:11px;font-weight:800;color:#5a3e00;letter-spacing:0.5px;">ACTIVIDAD RECIENTE</span>
                </div>
                @if (!actividadReciente.Any())
                {
                    <div style="text-align:center;color:#aaa;font-size:11px;padding:10px 0;">Sin actividad registrada</div>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:6px;max-height:180px;overflow-y:auto;">
                        @foreach (var act in actividadReciente)
                        {
                            <div style="display:flex;align-items:flex-start;gap:8px;padding:5px 0;border-bottom:1px solid #f5f0e0;">
                                <span style="font-size:14px;flex-shrink:0;">@act.Icono</span>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:10px;color:@act.Color;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@act.Descripcion</div>
                                    <div style="font-size:9px;color:#aaa;margin-top:1px;">@act.Fecha.ToString("dd/MM HH:mm")</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div style="background:#fff;border:1.5px solid @(productosVencer.Any() ? "#e67e22" : "#e8c840");border-radius:8px;padding:14px;box-shadow:0 2px 8px rgba(184,134,11,0.1);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;border-bottom:1px solid #f0d080;padding-bottom:8px;">
                    <span style="font-size:16px;">⚠️</span>
                    <span style="font-size:11px;font-weight:800;color:#5a3e00;letter-spacing:0.5px;">PRÓXIMOS A VENCER</span>
                    <span style="margin-left:auto;background:@(productosVencer.Any() ? "#e67e22" : "#27ae60");color:#fff;border-radius:12px;padding:1px 8px;font-size:10px;font-weight:700;">
                        @productosVencer.Count
                    </span>
                </div>
                @if (!productosVencer.Any())
                {
                    <div style="text-align:center;color:#27ae60;font-size:11px;font-weight:700;padding:10px 0;">✅ Ningún producto vence en 7 días</div>
                }
                else
                {
                    <div style="max-height:180px;overflow-y:auto;">
                        @foreach (var pv in productosVencer)
                        {
                            var diasRestantes = (pv.FechaVencimiento!.Value.Date - DateTime.Now.Date).Days;
                            var colorDias = diasRestantes <= 2 ? "#c0392b" : "#e67e22";
                            <div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid #f5f0e0;font-size:11px;">
                                <span style="color:#2a1800;font-weight:600;">@pv.Nombre</span>
                                <span style="color:@colorDias;font-weight:700;font-size:10px;">
                                    @(diasRestantes == 0 ? "¡Hoy!" : diasRestantes == 1 ? "Mañana" : $"{diasRestantes} días")
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>
            <div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:14px;box-shadow:0 2px 8px rgba(184,134,11,0.1);">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;border-bottom:1px solid #f0d080;padding-bottom:8px;">
                    <span style="font-size:16px;">🛡️</span>
                    <span style="font-size:11px;font-weight:800;color:#5a3e00;letter-spacing:0.5px;">ESTADO DEL SISTEMA</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;font-size:11px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;background:#fffbe6;border-radius:4px;padding:6px 10px;">
                        <span style="color:#7a5500;font-weight:600;">🗄️ Base de datos</span>
                        <span style="color:#27ae60;font-weight:700;">● Conectada</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;background:#fffbe6;border-radius:4px;padding:6px 10px;">
                        <span style="color:#7a5500;font-weight:600;">⚙️ Sistema</span>
                        <span style="color:#27ae60;font-weight:700;">● Operativo</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════
   PANEL: CLIENTES
   ══════════════════════════════════════════════ *@
<div class="panel" id="panel-clientes">
    <div class="panel-header">
        <img src="~/images/icon-clientes.png" alt="" onerror="this.style.display='none'" />
        <h3>REGISTRO CLIENTES</h3>
    </div>
    <div class="panel-body">
        <div class="panel-form-col">
            <div class="form-box">
                <div class="form-section-title">DATOS DEL CLIENTE</div>
                <div class="form-field">
                    <label>DOCUMENTO:</label>
                    <input type="text" id="cli-doc" maxlength="8" placeholder="12345678" />
                </div>
                <div class="form-field">
                    <label>NOMBRE:</label>
                    <input type="text" id="cli-nombre" />
                </div>
                <div class="form-field">
                    <label>APELLIDO:</label>
                    <input type="text" id="cli-apellido" />
                </div>
                <div class="form-field">
                    <label>DIRECCIÓN:</label>
                    <input type="text" id="cli-dir" />
                </div>
                <form asp-controller="Cliente" asp-action="Crear" method="post" id="form-cliente-crear">
                    <input type="hidden" name="Documento" id="h-cli-doc" />
                    <input type="hidden" name="Nombre" id="h-cli-nombre" />
                    <input type="hidden" name="Apellido" id="h-cli-apellido" />
                    <input type="hidden" name="Direccion" id="h-cli-dir" />
                    <input type="hidden" name="__panel" value="clientes" />
                </form>
                <form asp-controller="Cliente" asp-action="Editar" method="post" id="form-cliente-editar">
                    <input type="hidden" name="Id" id="h-cli-edit-id" />
                    <input type="hidden" name="Documento" id="h-cli-edit-doc" />
                    <input type="hidden" name="Nombre" id="h-cli-edit-nombre" />
                    <input type="hidden" name="Apellido" id="h-cli-edit-apellido" />
                    <input type="hidden" name="Direccion" id="h-cli-edit-dir" />
                    <input type="hidden" name="__panel" value="clientes" />
                </form>
                <form asp-controller="Cliente" asp-action="Eliminar" method="post" id="form-cliente-eliminar">
                    <input type="hidden" name="id" id="h-cli-id" />
                    <input type="hidden" name="__panel" value="clientes" />
                </form>
                @* Form para asignar usuario default al cliente *@
                <form asp-controller="Cliente" asp-action="AsignarUsuarioDefault" method="post" id="form-cli-asignar-usuario">
                    <input type="hidden" name="id" id="h-cli-asignar-id" />
                    <input type="hidden" name="__panel" value="clientes" />
                </form>
                <button type="button" class="btn-form-save" id="btn-cli-guardar" onclick="clienteGuardarOActualizar()">GUARDAR</button>
                <div class="btn-form-row">
                    <button type="button" class="btn-form-del" onclick="clienteEliminar()">ELIMINAR</button>
                    <button type="button" class="btn-form-mod" onclick="clienteModoEdicion()">MODIFICAR</button>
                </div>
            </div>
        </div>
        <div class="panel-table-col">
            <div class="search-bar">
                <label>BUSCAR CLIENTES:</label>
                <input type="text" id="search-clientes" oninput="filtrarClientes(this.value)" />
                <button class="btn-search" onclick="filtrarClientes(document.getElementById('search-clientes').value)">BUSCA</button>
                <button class="btn-clear" onclick="document.getElementById('search-clientes').value='';filtrarClientes('')">LIMPIAR</button>
            </div>
            <div class="data-table-wrap">
                <table class="data-table" id="tabla-clientes">
                    <thead>
                        <tr><th>Documento</th><th>Nombre</th><th>Apellido</th><th>Dirección</th><th>Usuario</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in ViewBag.Clientes as List<ENTIDADES.Cliente> ?? new List<ENTIDADES.Cliente>())
                        {
                            <tr onclick="seleccionarCliente(this,'@c.Id','@c.Documento','@c.Nombre','@c.Apellido','@Html.Raw(c.Direccion?.Replace("'", "\\'") ?? "")','@(c.Usuario?.NombreUsuario ?? "")')"
                                data-doc="@c.Documento"
                                data-nom="@(c.Nombre + " " + c.Apellido)"
                                data-tiene-usuario="@(c.Usuario != null ? "si" : "no")">
                                <td>@c.Documento</td>
                                <td>@c.Nombre</td>
                                <td>@c.Apellido</td>
                                <td>@c.Direccion</td>
                                <td>@(c.Usuario?.NombreUsuario ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @* ── TABLA FOOTER CLIENTES — botones nuevos ── *@
            <div class="table-footer">
                <button class="btn-add-user"
                        id="btn-asignar-usuario-cli"
                        onclick="clienteAsignarUsuario()"
                        disabled>
                    ASIGNAR USUARIO
                </button>
               
                
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════
   PANEL: PRODUCTOS
   ══════════════════════════════════════════════ *@
<div class="panel" id="panel-productos">
    <div class="panel-header">
        <img src="~/images/icon-productos.png" alt="" onerror="this.style.display='none'" />
        <h3>REGISTRO PRODUCTOS</h3>
    </div>
    <div class="panel-body">
        <div class="panel-form-col">
            <div class="form-box">
                <div class="form-section-title">DATOS DEL PRODUCTO</div>
                <div class="form-field"><label>NOMBRE:</label><input type="text" id="prod-nombre" /></div>
                <div class="form-field">
                    <label>CÓDIGO DE BARRAS:</label>
                    <input type="text" id="prod-codigo" maxlength="8" placeholder="12345678" />
                </div>
                <div class="form-field"><label>PRECIO:</label><input type="number" id="prod-precio" step="0.01" min="0" /></div>
                <div class="form-field"><label>STOCK:</label><input type="number" id="prod-stock" min="0" /></div>
                <div class="form-field" style="display:flex;align-items:center;gap:5px;">
                    <input type="checkbox" id="prod-perecedero" onchange="toggleFechaVenc(this)" />
                    <label class="form-check-label" for="prod-perecedero">Es Perecedero</label>
                </div>
                <div class="form-field" id="div-fecha-venc" style="display:none">
                    <label>FECHA VENCIMIENTO:</label>
                    <input type="date" id="prod-fecha-venc" />
                </div>
                <form asp-controller="Producto" asp-action="Crear" method="post" id="form-prod-crear">
                    <input type="hidden" name="Nombre" id="h-prod-nombre" />
                    <input type="hidden" name="CodigoBarra" id="h-prod-codigo" />
                    <input type="hidden" name="Precio" id="h-prod-precio" />
                    <input type="hidden" name="Stock" id="h-prod-stock" />
                    <input type="hidden" name="EsPerecedero" id="h-prod-perecedero" />
                    <input type="hidden" name="FechaVencimiento" id="h-prod-fecha-venc" />
                    <input type="hidden" name="__panel" value="productos" />
                </form>
                <form asp-controller="Producto" asp-action="Editar" method="post" id="form-prod-editar">
                    <input type="hidden" name="Id" id="h-prod-edit-id" />
                    <input type="hidden" name="Nombre" id="h-prod-edit-nombre" />
                    <input type="hidden" name="CodigoBarra" id="h-prod-edit-codigo" />
                    <input type="hidden" name="Precio" id="h-prod-edit-precio" />
                    <input type="hidden" name="Stock" id="h-prod-edit-stock" />
                    <input type="hidden" name="EsPerecedero" id="h-prod-edit-perecedero" />
                    <input type="hidden" name="FechaVencimiento" id="h-prod-edit-fecha-venc" />
                    <input type="hidden" name="__panel" value="productos" />
                </form>
                <form asp-controller="Producto" asp-action="Eliminar" method="post" id="form-prod-eliminar">
                    <input type="hidden" name="id" id="h-prod-del-id" />
                    <input type="hidden" name="__panel" value="productos" />
                </form>
