@model PROYECTO_WEB.TESIS.Models.CompraViewModel
@{
    ViewData["Title"] = "Nueva Compra";
}
<h2>Nueva Compra</h2>
<form asp-action="Crear" method="post" id="formCompra">
    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    <div class="row">
        <div class="col-md-4 mb-2">
            <label class="form-label">Proveedor</label>
            <select asp-for="ProveedorId" class="form-select" id="selectorProveedor" onchange="cargarProductos()">
                <option value="">-- Seleccione --</option>
                @foreach (var p in ViewBag.Proveedores as List<ENTIDADES.Proveedor>)
                {
                    <option value="@p.Id">@p.RazonSocial</option>
                }
            </select>
        </div>
        <div class="col-md-4 mb-2">
            <label asp-for="NumeroFactura" class="form-label">N° Factura</label>
            <input asp-for="NumeroFactura" class="form-control" />
        </div>
        <div class="col-md-4 mb-2">
            <label asp-for="FormaPago" class="form-label">Forma de Pago</label>
            <select asp-for="FormaPago" class="form-select">
                <option value="Efectivo">Efectivo</option>
                <option value="Transferencia">Transferencia</option>
                <option value="Cheque">Cheque</option>
            </select>
        </div>
    </div>

    <h5 class="mt-3">Agregar Producto</h5>
    <div class="row mb-2">
        <div class="col-md-4">
            <select id="selectorProducto" class="form-select"></select>
        </div>
        <div class="col-md-2">
            <input type="number" id="cantidadProducto" class="form-control" placeholder="Cantidad" min="1" value="1" />
        </div>
        <div class="col-md-2">
            <input type="number" id="precioUnitario" class="form-control" placeholder="Precio Unitario" step="0.01" />
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-warning" onclick="agregarProducto()">Agregar</button>
        </div>
    </div>

    <table class="table table-bordered">
        <thead class="table-light">
            <tr><th>Producto</th><th>Cantidad</th><th>Precio Unit.</th><th>Subtotal</th><th></th></tr>
        </thead>
        <tbody id="tbodyDetalle"></tbody>
        <tfoot><tr><td colspan="3" class="text-end fw-bold">Total:</td><td id="totalCompra" class="fw-bold">$0.00</td><td></td></tr></tfoot>
    </table>

    <div id="hiddenDetalles"></div>
    <button type="submit" class="btn btn-warning" id="btnFinalizar" disabled>Finalizar Compra</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <script>
        let detalles = [];

        function cargarProductos() {
            const provId = document.getElementById('selectorProveedor').value;
            if (!provId) return;
            fetch('/Compra/ObtenerProductosProveedor?proveedorId=' + provId)
                .then(r => r.json())
                .then(data => {
                    const sel = document.getElementById('selectorProducto');
                    sel.innerHTML = '<option value="">-- Seleccione producto --</option>';
                    data.forEach(p => {
                        sel.innerHTML += `<option value="${p.id}" data-precio="${p.precio}" data-nombre="${p.nombre}" data-stock="${p.stock}">${p.nombre} (Stock: ${p.stock})</option>`;
                    });
                });
        }

        function agregarProducto() {
            const sel = document.getElementById('selectorProducto');
            const opt = sel.options[sel.selectedIndex];
            if (!opt.value) return alert('Seleccione un producto');
            const cant = parseInt(document.getElementById('cantidadProducto').value);
            const precio = parseFloat(document.getElementById('precioUnitario').value);
            if (cant <= 0 || isNaN(precio) || precio <= 0) return alert('Ingrese cantidad y precio válidos');

            detalles.push({ productoId: opt.value, nombre: opt.dataset.nombre, cantidad: cant, precio: precio, subtotal: cant * precio });
            renderTabla();
        }

        function eliminarDetalle(idx) { detalles.splice(idx, 1); renderTabla(); }

        function renderTabla() {
            const tbody = document.getElementById('tbodyDetalle');
            tbody.innerHTML = '';
            let total = 0;
            detalles.forEach((d, i) => {
                total += d.subtotal;
                tbody.innerHTML += `<tr><td>${d.nombre}</td><td>${d.cantidad}</td><td>$${d.precio.toFixed(2)}</td><td>$${d.subtotal.toFixed(2)}</td><td><button type="button" class="btn btn-sm btn-danger" onclick="eliminarDetalle(${i})">X</button></td></tr>`;
            });
            document.getElementById('totalCompra').textContent = '$' + total.toFixed(2);
            document.getElementById('btnFinalizar').disabled = detalles.length === 0;
            const hidden = document.getElementById('hiddenDetalles');
            hidden.innerHTML = '';
            detalles.forEach((d, i) => {
                hidden.innerHTML += `<input type="hidden" name="Detalles[${i}].ProductoId" value="${d.productoId}"/>
                    <input type="hidden" name="Detalles[${i}].ProductoNombre" value="${d.nombre}"/>
                    <input type="hidden" name="Detalles[${i}].Cantidad" value="${d.cantidad}"/>
                    <input type="hidden" name="Detalles[${i}].PrecioUnitario" value="${d.precio}"/>`;
            });
        }
    </script>
}