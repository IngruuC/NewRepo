@model ENTIDADES.Producto
@{
    ViewData["Title"] = "Editar Producto";
}
<h2>Editar Producto</h2>
<div class="row">
    <div class="col-md-6">
        <form asp-action="Editar" method="post">
            <input asp-for="Id" type="hidden" />
            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            <div class="mb-2"><label asp-for="Nombre" class="form-label">Nombre</label><input asp-for="Nombre" class="form-control" /></div>
            <div class="mb-2"><label asp-for="CodigoBarra" class="form-label">Código de Barras</label><input asp-for="CodigoBarra" class="form-control" maxlength="8" /></div>
            <div class="mb-2"><label asp-for="Precio" class="form-label">Precio</label><input asp-for="Precio" class="form-control" type="number" step="0.01" /></div>
            <div class="mb-2"><label asp-for="Stock" class="form-label">Stock</label><input asp-for="Stock" class="form-control" type="number" /></div>
            <div class="mb-2 form-check"><input asp-for="EsPerecedero" class="form-check-input" id="perecedero" /><label asp-for="EsPerecedero" class="form-check-label">Es Perecedero</label></div>
            <div class="mb-2" id="divFechaVenc">
                <label asp-for="FechaVencimiento" class="form-label">Fecha de Vencimiento</label>
                <input asp-for="FechaVencimiento" class="form-control" type="date" />
            </div>
            <button type="submit" class="btn btn-warning">Actualizar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
@section Scripts {
    <script>
        var perecedero = document.getElementById('perecedero');
        document.getElementById('divFechaVenc').style.display = perecedero.checked ? '' : 'none';
        perecedero.addEventListener('change', function(){
            document.getElementById('divFechaVenc').style.display = this.checked ? '' : 'none';
        });
    </script>
}