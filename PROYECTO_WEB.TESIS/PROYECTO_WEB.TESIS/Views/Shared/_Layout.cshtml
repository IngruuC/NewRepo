<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fresco Market</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var grupos = Context.Session.GetString("UsuarioGrupos") ?? "[]";
        var esAdmin = grupos.Contains("ADMINISTRADOR");
        var esCliente = grupos.Contains("CLIENTE");
        var esProveedor = grupos.Contains("PROVEEDOR");
        var logueado = Context.Session.GetInt32("UsuarioId").HasValue;
    }

    @if (logueado)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-success">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="#">🛒 Fresco Market</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        @if (esAdmin)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Ventas</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Venta" asp-action="Crear">Nueva Venta</a></li>
                                    <li><a class="dropdown-item" asp-controller="Venta" asp-action="Index">Ver Ventas</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Compras</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Compra" asp-action="Crear">Nueva Compra</a></li>
                                    <li><a class="dropdown-item" asp-controller="Compra" asp-action="Index">Ver Compras</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Gestión</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Producto" asp-action="Index">Productos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Cliente" asp-action="Index">Clientes</a></li>
                                    <li><a class="dropdown-item" asp-controller="Proveedor" asp-action="Listar">Proveedores</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Seguridad</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Usuario" asp-action="Index">Usuarios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Grupo" asp-action="Index">Grupos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Auditoria" asp-action="Index">Auditoría</a></li>
                                </ul>
                            </li>
                        }
                        @if (esCliente)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="PanelCliente" asp-action="Index">Inicio</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="PanelCliente" asp-action="MisCompras">Mis Compras</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="PanelCliente" asp-action="Perfil">Mi Perfil</a></li>
                        }
                        @if (esProveedor)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Proveedor" asp-action="Index">Mi Panel</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <span class="nav-link text-white">👤 @Context.Session.GetString("UsuarioNombre")</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">Cerrar Sesión</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>