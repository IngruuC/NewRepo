@{
    ViewData["Title"] = "Panel Cliente";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    var cliente = ViewBag.Cliente as ENTIDADES.Cliente;
    var productos = ViewBag.Productos as List<ENTIDADES.Producto> ?? new List<ENTIDADES.Producto>();
    var misVentas = ViewBag.MisVentas as List<ENTIDADES.Venta> ?? new List<ENTIDADES.Venta>();
    var promosVigentes = ViewBag.PromocionesVigentes as List<ENTIDADES.Promocion> ?? new List<ENTIDADES.Promocion>();
    var favoritosIds = ViewBag.FavoritosIds as List<int> ?? new List<int>();
}

@* PANEL: INICIO *@
<div class="panel active" id="panel-inicio">
    <div class="panel-header">
        <h3>PRODUCTOS DISPONIBLES</h3>
    </div>
    <div class="panel-full" style="padding:14px;">
        <div class="search-bar" style="margin-bottom:10px;">
            <label>BUSCAR:</label>
            <input type="text" id="search-inicio" oninput="filtrarProductosInicio(this.value)" placeholder="Nombre del producto..." />
            <button class="btn-search" onclick="filtrarProductosInicio(document.getElementById('search-inicio').value)">BUSCAR</button>
            <button class="btn-clear" onclick="document.getElementById('search-inicio').value='';filtrarProductosInicio('')">LIMPIAR</button>
        </div>
        <div class="productos-grid" id="grid-productos">
            @foreach (var p in productos)
            {
                var promo = promosVigentes.FirstOrDefault(pr => pr.ProductoId == p.Id);
                var precioFinal = promo != null ? promo.AplicarDescuento(p.Precio) : p.Precio;
                var esFavorito = favoritosIds.Contains(p.Id);
                <div class="producto-card" data-nom="@p.Nombre.ToLower()">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px;">
                        <div class="producto-card-nombre">@p.Nombre</div>
                        <button type="button"
                                class="btn-corazon @(esFavorito ? "corazon-activo" : "")"
                                id="corazon-@p.Id"
                                onclick="toggleFavorito(@p.Id, '@Html.Raw(p.Nombre.Replace("'", "\\'"))', @precioFinal.ToString(System.Globalization.CultureInfo.InvariantCulture), @p.Stock)">
                            @(esFavorito ? "♥" : "♡")
                        </button>
                    </div>

                    @if (promo != null)
                    {
                        <div style="background:#e74c3c;color:#fff;font-size:10px;font-weight:700;
                            border-radius:4px;padding:2px 8px;display:inline-block;margin-bottom:4px;">
                            🏷️ @(promo.TipoDescuento == "Porcentaje"
                                                            ? $"{promo.ValorDescuento:0.##}% OFF"
                                                            : $"${promo.ValorDescuento:N2} OFF")
                            @if (!string.IsNullOrEmpty(promo.Descripcion))
                            {
                                <span> — @promo.Descripcion</span>
                            }
                        </div>
                    }

                    @if (p.EsPerecedero && p.FechaVencimiento.HasValue)
                    {
                        <div class="producto-card-vence">⚠️ Vence: @p.FechaVencimiento.Value.ToString("dd/MM/yyyy")</div>
                    }

                    @if (promo != null)
                    {
                        <div style="display:flex;align-items:center;gap:6px;">
                            <div class="producto-card-precio" style="color:#e74c3c;">$@precioFinal.ToString("N2")</div>
                            <div style="font-size:11px;color:#aaa;text-decoration:line-through;">$@p.Precio.ToString("N2")</div>
                        </div>
                    }
                    else
                    {
                        <div class="producto-card-precio">$@p.Precio.ToString("N2")</div>
                    }

                    <div class="producto-card-stock @(p.Stock <= 5 ? "stock-bajo" : "")">
                        Stock: @p.Stock ud.
                    </div>
                    <div class="producto-card-acciones">
                        <button class="btn-agregar-carrito"
                                onclick="carritoAgregarProducto(@p.Id, '@Html.Raw(p.Nombre.Replace("'", "\\'"))', @precioFinal.ToString(System.Globalization.CultureInfo.InvariantCulture), @p.Stock)">
                            🛒 Agregar
                        </button>
                        <button class="btn-ver-detalles"
                                onclick="verDetallesProducto(@p.Id, '@Html.Raw(p.Nombre.Replace("'", "\\'"))', @precioFinal.ToString(System.Globalization.CultureInfo.InvariantCulture), @p.Stock, '@(p.EsPerecedero ? "Sí" : "No")', '@(p.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "-")', @p.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture), @(promo != null ? "true" : "false"))">
                            Ver Detalles
                        </button>
                    </div>
                </div>
            }
            @if (!productos.Any())
            {
                <div style="color:#7a5500;font-size:13px;padding:20px;grid-column:1/-1;">No hay productos disponibles.</div>
            }
        </div>
    </div>
</div>

@* PANEL: MI PERFIL *@
<div class="panel" id="panel-perfil">
    <div class="panel-header"><h3>MI PERFIL</h3></div>
    <div class="panel-full" style="padding:14px;">
        <div class="perfil-box">
            <div class="perfil-section-title">Datos Personales</div>
            <div class="perfil-field"><label>Nombre:</label><input type="text" id="pf-nombre" value="@cliente?.Nombre" /></div>
            <div class="perfil-field"><label>Apellido:</label><input type="text" id="pf-apellido" value="@cliente?.Apellido" /></div>
            <div class="perfil-field"><label>Documento:</label><input type="text" id="pf-doc" value="@cliente?.Documento" readonly style="background:#f5e888;" /></div>
            <div class="perfil-field"><label>Dirección:</label><input type="text" id="pf-dir" value="@cliente?.Direccion" /></div>
            <div class="perfil-field"><label>Email:</label><input type="text" id="pf-email" value="@cliente?.Usuario?.Email" readonly style="background:#f5e888;" /></div>

            <form asp-controller="PanelCliente" asp-action="Perfil" method="post" id="form-perfil">
                <input type="hidden" name="Id" value="@cliente?.Id" />
                <input type="hidden" name="Documento" value="@cliente?.Documento" />
                <input type="hidden" name="UsuarioId" value="@cliente?.UsuarioId" />
                <input type="hidden" name="Nombre" id="h-pf-nombre" />
                <input type="hidden" name="Apellido" id="h-pf-apellido" />
                <input type="hidden" name="Direccion" id="h-pf-dir" />
                <input type="hidden" name="__panel" value="perfil" />
            </form>

            <div class="perfil-btns">
                <button class="btn-pf-cambiar" onclick="abrirModalCambioContrasena()">Cambiar Contraseña</button>
                <button class="btn-pf-guardar" onclick="guardarPerfil()">Guardar Cambios</button>
                <button class="btn-pf-cancelar" onclick="cancelarPerfil('@cliente?.Nombre','@cliente?.Apellido','@Html.Raw(cliente?.Direccion?.Replace("'", "\\'") ?? "")')">Cancelar</button>
            </div>
        </div>
    </div>
</div>

@* PANEL: COMPRAS *@
<div class="panel" id="panel-compras">
    <div class="panel-header"><h3>MIS COMPRAS</h3></div>
    <div class="panel-body">
        <div class="panel-form-col">
            <div class="form-box" style="display:flex;flex-direction:column;gap:6px;">
                <div class="form-section-title">ACCIONES</div>
                <button class="btn-form-save" style="background:#2980b9;border-color:#1a5276;color:#fff"
                        id="btn-ver-det-compra" onclick="compraVerDetalle()" disabled>
                    VER DETALLE
                </button>
            </div>
        </div>
        <div class="panel-table-col">
            <div class="search-bar" style="flex-wrap:wrap;gap:5px;">
                <div style="display:flex;align-items:center;gap:5px;">
                    <label class="vt-lbl">DESDE</label>
                    <input type="date" id="comp-desde" class="vt-date" />
                    <label class="vt-lbl">HASTA</label>
                    <input type="date" id="comp-hasta" class="vt-date" />
                    <button class="btn-search" onclick="comprasFiltrar()">FILTRAR</button>
                    <button class="btn-clear" onclick="comprasLimpiar()">LIMPIAR</button>
                </div>
            </div>
            <div class="data-table-wrap" style="margin-top:6px;">
                <table class="data-table" id="tabla-mis-compras">
                    <thead><tr><th>ID</th><th>Fecha</th><th>Forma de Pago</th><th>Total</th></tr></thead>
                    <tbody>
                        @foreach (var v in misVentas)
                        {
                            <tr onclick="compraSeleccionar(this)"
                                data-id="@v.Id"
                                data-fecha="@v.FechaVenta.ToString("dd/MM/yyyy HH:mm")"
                                data-formapago="@v.FormaPago"
                                data-total="@v.Total.ToString("N2")"
                                data-detalles="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(v.Detalles.Select(d => new { nombre = d.ProductoNombre, cantidad = d.Cantidad, precio = d.PrecioUnitario.ToString("N2"), subtotal = d.Subtotal.ToString("N2") })).Replace("\"", "&quot;"))">
                                <td>@v.Id</td>
                                <td>@v.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@v.FormaPago</td>
                                <td>$@v.Total.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* PANEL: SUSCRIPCION *@
<div class="panel" id="panel-suscripcion">
    <div class="panel-header"><h3>MI SUSCRIPCIÓN</h3></div>
    <div class="panel-full" style="padding:14px;">

        <div id="susc-estado-box" style="margin-bottom:16px;">
            <div style="text-align:center;color:#aaa;font-size:12px;padding:20px;">Cargando...</div>
        </div>

        <div id="susc-planes-box" style="margin-bottom:16px;">
            <div style="font-size:12px;font-weight:700;color:#5a3e00;
                border-bottom:1px solid #d4a017;padding-bottom:6px;margin-bottom:10px;">
                PLANES DISPONIBLES
            </div>
            <div id="susc-planes-grid"
                 style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">
                <div style="text-align:center;color:#aaa;padding:20px;">Cargando planes...</div>
            </div>
        </div>

        <div id="susc-historial-box">
            <div style="font-size:12px;font-weight:700;color:#5a3e00;
                border-bottom:1px solid #d4a017;padding-bottom:6px;margin-bottom:10px;">
                HISTORIAL DE PAGOS
            </div>
            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr><th>Plan</th><th>Monto</th><th>Solicitud</th><th>Aprobación</th><th>Estado</th></tr>
                    </thead>
                    <tbody id="susc-historial-tbody">
                        <tr><td colspan="5" style="text-align:center;color:#aaa;padding:14px;">Sin historial.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@* PANEL: FAVORITOS *@
<div class="panel" id="panel-favoritos">
    <div class="panel-header"><h3>MIS FAVORITOS</h3></div>
    <div class="panel-full" style="padding:14px;">
        <div class="data-table-wrap">
            <table class="data-table" id="tabla-favoritos">
                <thead><tr><th>ID</th><th>Nombre</th><th>Precio</th><th>Stock</th><th>Acciones</th></tr></thead>
                <tbody id="fav-tbody">
                    <tr id="fav-empty"><td colspan="5" style="text-align:center;color:#aaa;padding:14px;">No tenés favoritos agregados.</td></tr>
                </tbody>
            </table>
        </div>
        <div style="display:flex;gap:10px;margin-top:10px;align-items:center;">
            <span id="fav-total-lbl" style="font-size:11px;font-weight:700;color:#7a5500;">Total de favoritos: 0</span>
            <button class="btn-agregar-fav" onclick="abrirModalAgregarFavorito()">Agregar Favorito</button>
        </div>
    </div>
</div>

@* MODAL: CARRITO *@
<div id="modal-carrito" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:700px;max-width:96vw;max-height:90vh;display:flex;flex-direction:column;">
        <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
            <span style="font-size:13px;font-weight:700;color:#3a2500;">🛒 CARRITO DE COMPRAS</span>
            <button onclick="cerrarCarrito()" style="background:#8B6508;border:none;color:#f5d060;border-radius:50%;width:22px;height:22px;cursor:pointer;font-weight:700;">✕</button>
        </div>
        <div style="overflow-y:auto;flex:1;padding:10px;">
            <table class="data-table" style="min-width:520px;">
                <thead><tr><th>Producto</th><th>Precio</th><th>Cantidad</th><th>Subtotal</th><th>Eliminar</th></tr></thead>
                <tbody id="carrito-tbody">
                    <tr id="carrito-empty"><td colspan="5" style="text-align:center;color:#aaa;padding:12px;">El carrito está vacío</td></tr>
                </tbody>
            </table>
        </div>
        <div style="padding:10px 14px;border-top:1px solid #e8c840;flex-shrink:0;">
            <div style="font-size:14px;font-weight:700;color:#5a3e00;margin-bottom:8px;">Total: $<span id="carrito-total">0.00</span></div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <button class="btn-pf-cancelar" onclick="vaciarCarrito()">Vaciar Carrito</button>
                <button class="btn-pf-cancelar" onclick="cerrarCarrito()">Seguir Comprando</button>
                <button class="btn-pf-guardar" id="btn-finalizar-compra" onclick="abrirModalFormaPago()" disabled>Finalizar Compra</button>
            </div>
        </div>
    </div>
</div>

@* MODAL: FORMA DE PAGO *@
<div id="modal-forma-pago" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:3000;align-items:center;justify-content:center;">
    <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:360px;max-width:95vw;">
        <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;">
            <span style="font-size:13px;font-weight:700;color:#3a2500;">Seleccionar Forma de Pago</span>
        </div>
        <div style="padding:18px;">
            <div style="font-size:12px;font-weight:700;color:#5a3e00;margin-bottom:10px;">Seleccione forma de pago:</div>
            <select id="sel-forma-pago" class="seg-fselect" style="width:100%;margin-bottom:16px;"
                    onchange="actualizarInfoPago()">
                <option value="Efectivo">Efectivo (15% desc.)</option>
                <option value="Tarjeta de Crédito">Tarjeta de Crédito (10% rec.)</option>
                <option value="Tarjeta de Débito">Tarjeta de Débito</option>
            </select>
            <div id="susc-descuento-info" style="display:none;background:#eafaf1;border:1px solid #27ae60;
                border-radius:4px;padding:8px;font-size:11px;color:#1e8449;font-weight:700;margin-top:6px;">
                👑 Descuento suscriptor 5% aplicado
            </div>
            <div id="pago-precio-desglose" style="font-size:11px;color:#7a5500;margin-top:6px;"></div>
            <form asp-controller="PanelCliente" asp-action="RealizarCompra" method="post" id="form-venta-cliente">
                <input type="hidden" name="ClienteId" id="h-venta-cliente-id" value="@cliente?.Id" />
                <input type="hidden" name="FormaPago" id="h-venta-forma-pago" />
                <input type="hidden" name="__panel" value="compras" />
                <div id="h-venta-detalles"></div>
            </form>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:12px;">
                <button class="btn-pf-cancelar" onclick="cerrarModalFormaPago()">Cancelar</button>
                <button class="btn-pf-guardar" onclick="finalizarCompra()">Aceptar</button>
            </div>
        </div>
    </div>
</div>

@* MODAL: DETALLES PRODUCTO *@
<div id="modal-producto" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:400px;max-width:95vw;">
        <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:13px;font-weight:700;color:#3a2500;">📦 DETALLES DEL PRODUCTO</span>
            <button onclick="cerrarModalProducto()" style="background:#8B6508;border:none;color:#f5d060;border-radius:50%;width:22px;height:22px;cursor:pointer;font-weight:700;">✕</button>
        </div>
        <div id="modal-producto-body" style="padding:16px;font-size:12px;color:#2a1800;line-height:1.9;background:#fff;"></div>
        <div style="padding:8px 14px;text-align:right;border-top:1px solid #e8c840;">
            <button class="btn-pf-cancelar" onclick="cerrarModalProducto()">Cerrar</button>
        </div>
    </div>
</div>

@* MODAL: DETALLE COMPRA *@
<div id="modal-det-compra" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:500px;max-width:95vw;max-height:85vh;display:flex;flex-direction:column;">
        <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:13px;font-weight:700;color:#3a2500;">Detalle de Compra</span>
            <button onclick="cerrarModalDetCompra()" style="background:#8B6508;border:none;color:#f5d060;border-radius:50%;width:22px;height:22px;cursor:pointer;font-weight:700;">✕</button>
        </div>
        <div id="modal-det-compra-body" style="padding:14px;overflow-y:auto;flex:1;font-size:12px;color:#2a1800;white-space:pre-wrap;font-family:'Courier New',monospace;line-height:1.6;background:#fff;"></div>
        <div style="padding:8px 14px;text-align:right;border-top:1px solid #e8c840;">
            <button class="btn-pf-cancelar" onclick="cerrarModalDetCompra()">Cerrar</button>
        </div>
    </div>
</div>

@* MODAL: AGREGAR FAVORITO *@
<div id="modal-agregar-fav" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:520px;max-width:95vw;max-height:85vh;display:flex;flex-direction:column;">
        <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:13px;font-weight:700;color:#3a2500;">Agregar Favorito</span>
            <button onclick="cerrarModalAgregarFav()" style="background:#8B6508;border:none;color:#f5d060;border-radius:50%;width:22px;height:22px;cursor:pointer;font-weight:700;">✕</button>
        </div>
        <div style="padding:10px;overflow-y:auto;flex:1;">
            <div class="search-bar" style="margin-bottom:8px;">
                <label>BUSCAR:</label>
                <input type="text" id="fav-buscar-input" oninput="favFiltrarBusqueda(this.value)" />
            </div>
            <div class="data-table-wrap">
                <table class="data-table" id="tabla-buscar-prod">
                    <thead><tr><th>ID</th><th>Nombre</th><th>Precio</th><th>Stock</th></tr></thead>
                    <tbody id="buscar-prod-tbody">
                        @foreach (var p in productos)
                        {
                            var promo = promosVigentes.FirstOrDefault(pr => pr.ProductoId == p.Id);
                            var precioFinal = promo != null ? promo.AplicarDescuento(p.Precio) : p.Precio;
                            <tr onclick="favSeleccionarProducto(this, @p.Id, '@Html.Raw(p.Nombre.Replace("'", "\\'"))', @precioFinal.ToString(System.Globalization.CultureInfo.InvariantCulture), @p.Stock)"
                                data-nom="@p.Nombre.ToLower()">
                                <td>@p.Id</td>
                                <td>@p.Nombre @(promo != null ? "🏷️" : "")</td>
                                <td>$@precioFinal.ToString("N2")</td>
                                <td>@p.Stock</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div style="padding:8px 14px;border-top:1px solid #e8c840;display:flex;gap:8px;justify-content:flex-end;">
            <button class="btn-pf-cancelar" onclick="cerrarModalAgregarFav()">Cancelar</button>
            <button class="btn-pf-guardar" onclick="favAgregarSeleccionado()">Agregar</button>
        </div>
    </div>
</div>

@* MODAL: CAMBIO CONTRASEÑA *@
<div id="modal-cambio-pass" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.55);z-index:2000;align-items:center;justify-content:center;">
    <div style="background:#fffbe6;border:2px solid #b8860b;border-radius:8px;width:420px;max-width:95vw;">
        <div style="background:#d4a017;padding:8px 14px;border-radius:6px 6px 0 0;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:13px;font-weight:700;color:#3a2500;">Cambiar Contraseña</span>
            <button onclick="cerrarModalCambioPass()" style="background:#8B6508;border:none;color:#f5d060;border-radius:50%;width:22px;height:22px;cursor:pointer;font-weight:700;">✕</button>
        </div>
        <div style="padding:14px;">
            <div class="perfil-field"><label>Contraseña Actual:</label><input type="password" id="pass-actual" /></div>
            <div class="perfil-field"><label>Nueva Contraseña:</label><input type="password" id="pass-nueva" /></div>
            <div class="perfil-field"><label>Confirmar Nueva Contraseña:</label><input type="password" id="pass-confirmar" /></div>
            <form asp-controller="PanelCliente" asp-action="CambiarContrasena" method="post" id="form-cambio-pass">
                <input type="hidden" name="contrasenaActual" id="h-pass-actual" />
                <input type="hidden" name="nuevaContrasena" id="h-pass-nueva" />
            </form>
            <div style="display:flex;gap:8px;margin-top:12px;justify-content:flex-end;">
                <button class="btn-pf-cancelar" onclick="cerrarModalCambioPass()">Cancelar</button>
                <button class="btn-pf-guardar" onclick="guardarCambioPass()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ══════════════════════════════════════════════
        // ESTADO GLOBAL
        // ══════════════════════════════════════════════
        var carritoItems = [];
        var compraSeleccionadaFila = null;
        var favoritosItems = [];
        var favProdSeleccionado = null;

        // ══════════════════════════════════════════════
        // CARRITO — persistido en sessionStorage
        // ══════════════════════════════════════════════
        function _carritoGuardar() {
            try { sessionStorage.setItem('carritoItems', JSON.stringify(carritoItems)); } catch(e) {}
        }

        function _carritoCargar() {
            try {
                var saved = sessionStorage.getItem('carritoItems');
                if (saved) carritoItems = JSON.parse(saved);
                else carritoItems = [];
            } catch(e) { carritoItems = []; }
        }

        function carritoAgregarProducto(id, nombre, precio, stock) {
            _carritoCargar();
            var existing = carritoItems.find(function(i) { return i.id === id; });
            if (existing) {
                if (existing.cantidad >= stock) {
                    alert('Stock insuficiente. Solo hay ' + stock + ' unidades.');
                    return;
                }
                existing.cantidad++;
            } else {
                if (stock <= 0) { alert('Sin stock disponible.'); return; }
                carritoItems.push({ id: id, nombre: nombre, precio: precio, cantidad: 1, stock: stock });
            }
            _carritoGuardar();
            carritoActualizarBadge();
            // Toast de confirmación
            var t = document.createElement('div');
            t.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;padding:10px 18px;'
                + 'background:#d5f5e3;color:#1a5c38;border:1.5px solid #27ae60;border-radius:6px;'
                + 'font-size:12px;font-weight:600;box-shadow:0 2px 8px rgba(0,0,0,0.15);';
            t.textContent = '✓ ' + nombre + ' agregado al carrito';
            document.body.appendChild(t);
            setTimeout(function() { t.remove(); }, 2000);
        }

        function carritoActualizarBadge() {
            _carritoCargar();
            var total = carritoItems.reduce(function(s, i) { return s + i.cantidad; }, 0);
            var badge = document.getElementById('carrito-badge');
            if (badge) {
                badge.textContent = total;
                badge.style.display = total > 0 ? 'flex' : 'none';
            }
        }

        function abrirCarrito() {
            _carritoCargar();
            carritoRenderTabla();
            document.getElementById('modal-carrito').style.display = 'flex';
        }

        function cerrarCarrito() {
            document.getElementById('modal-carrito').style.display = 'none';
        }

        function carritoRenderTabla() {
            _carritoCargar();
            var tbody = document.getElementById('carrito-tbody');
            if (!carritoItems.length) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#aaa;padding:12px;">El carrito está vacío</td></tr>';
                document.getElementById('carrito-total').textContent = '0.00';
                document.getElementById('btn-finalizar-compra').disabled = true;
                return;
            }
            var total = 0;
            tbody.innerHTML = '';
            carritoItems.forEach(function(item, i) {
                var sub = item.precio * item.cantidad;
                total += sub;
                tbody.innerHTML += '<tr>'
                    + '<td>' + item.nombre + '</td>'
                    + '<td>$' + parseFloat(item.precio).toFixed(2) + '</td>'
                    + '<td><input type="number" min="1" max="' + item.stock + '" value="' + item.cantidad
                    + '" style="width:55px;border:1px solid #c8a000;border-radius:3px;padding:2px 4px;"'
                    + ' onchange="carritoModCantidad(' + i + ',this.value)" /></td>'
                    + '<td>$' + sub.toFixed(2) + '</td>'
                    + '<td><button class="btn-form-del" style="padding:2px 8px" onclick="carritoEliminar(' + i + ')">X</button></td>'
                    + '</tr>';
            });
            document.getElementById('carrito-total').textContent = total.toFixed(2);
            document.getElementById('btn-finalizar-compra').disabled = false;
        }

        function carritoModCantidad(idx, val) {
            _carritoCargar();
            var cant = parseInt(val) || 1;
            if (cant <= 0) cant = 1;
            if (cant > carritoItems[idx].stock) {
                cant = carritoItems[idx].stock;
                alert('Stock máximo: ' + carritoItems[idx].stock);
            }
            carritoItems[idx].cantidad = cant;
            _carritoGuardar();
            carritoRenderTabla();
            carritoActualizarBadge();
        }

        function carritoEliminar(idx) {
            _carritoCargar();
            carritoItems.splice(idx, 1);
            _carritoGuardar();
            carritoRenderTabla();
            carritoActualizarBadge();
        }

        function vaciarCarrito() {
            if (!confirm('¿Vaciar el carrito?')) return;
            carritoItems = [];
            _carritoGuardar();
            carritoRenderTabla();
            carritoActualizarBadge();
        }

        // ══════════════════════════════════════════════
        // MODAL FORMA DE PAGO — no bloquea si falla fetch
        // ══════════════════════════════════════════════
        function abrirModalFormaPago() {
            _carritoCargar();
            if (!carritoItems.length) { alert('El carrito está vacío.'); return; }

            // Intentar obtener suscripción pero NO bloquear si falla
            fetch('/Suscripcion/MiSuscripcion')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    window._clienteTieneSusc = data.ok && data.tieneSuscripcion;
                })
                .catch(function() {
                    window._clienteTieneSusc = false;
                })
                .finally(function() {
                    actualizarInfoPago();
                    document.getElementById('modal-forma-pago').style.display = 'flex';
                });
        }

        function cerrarModalFormaPago() {
            document.getElementById('modal-forma-pago').style.display = 'none';
        }

        function actualizarInfoPago() {
            _carritoCargar();
            var fp = document.getElementById('sel-forma-pago').value;
            var base = carritoItems.reduce(function(s, i) {
                return s + parseFloat(i.precio) * i.cantidad;
            }, 0);

            var totalFP = fp === 'Efectivo' ? base * 0.85
                        : fp === 'Tarjeta de Crédito' ? base * 1.10
                        : base;

            var totalFinal = window._clienteTieneSusc ? totalFP * 0.95 : totalFP;

            var desglose = document.getElementById('pago-precio-desglose');
            var suscInfo = document.getElementById('susc-descuento-info');

            if (desglose) {
                var txt = '';
                if (fp === 'Efectivo')
                    txt += 'Descuento efectivo 15%: -$' + (base * 0.15).toFixed(2) + '<br>';
                else if (fp === 'Tarjeta de Crédito')
                    txt += 'Recargo tarjeta 10%: +$' + (base * 0.10).toFixed(2) + '<br>';
                if (window._clienteTieneSusc)
                    txt += 'Descuento suscriptor 5%: -$' + (totalFP * 0.05).toFixed(2) + '<br>';
                txt += '<strong>Total a pagar: $' + totalFinal.toFixed(2) + '</strong>';
                desglose.innerHTML = txt;
                desglose.style.display = 'block';
            }

            if (suscInfo)
                suscInfo.style.display = window._clienteTieneSusc ? 'block' : 'none';
        }

        function finalizarCompra() {
            _carritoCargar();
            if (!carritoItems.length) { alert('El carrito está vacío.'); return; }

            var formaPago = document.getElementById('sel-forma-pago').value;
            document.getElementById('h-venta-forma-pago').value = formaPago;

            var hiddenDiv = document.getElementById('h-venta-detalles');
            hiddenDiv.innerHTML = '';
            carritoItems.forEach(function(d, idx) {
                hiddenDiv.innerHTML +=
                    '<input type="hidden" name="Detalles[' + idx + '].ProductoId" value="' + d.id + '"/>'
                    + '<input type="hidden" name="Detalles[' + idx + '].ProductoNombre" value="' + d.nombre + '"/>'
                    + '<input type="hidden" name="Detalles[' + idx + '].Cantidad" value="' + d.cantidad + '"/>'
                    + '<input type="hidden" name="Detalles[' + idx + '].PrecioUnitario" value="' + d.precio + '"/>';
            });

            // Limpiar carrito antes de submit
            carritoItems = [];
            _carritoGuardar();
            carritoActualizarBadge();

            document.getElementById('form-venta-cliente').submit();
        }

        // ══════════════════════════════════════════════
        // BÚSQUEDA INICIO
        // ══════════════════════════════════════════════
        function filtrarProductosInicio(val) {
            var q = val.toLowerCase();
            document.querySelectorAll('#grid-productos .producto-card').forEach(function(card) {
                card.style.display = (!q || (card.dataset.nom || '').includes(q)) ? '' : 'none';
            });
        }

        // ══════════════════════════════════════════════
        // DETALLES PRODUCTO
        // ══════════════════════════════════════════════
        function verDetallesProducto(id, nombre, precio, stock, perecedero, vencimiento, precioOriginal, tienePromo) {
            var body = '<strong>Nombre:</strong> ' + nombre + '<br>';
            if (tienePromo === true || tienePromo === 'true') {
                body += '<strong>Precio original:</strong> <span style="text-decoration:line-through;color:#aaa;">$'
                    + parseFloat(precioOriginal).toFixed(2) + '</span><br>';
                body += '<strong>Precio con promo:</strong> <span style="color:#e74c3c;font-weight:700;">$'
                    + parseFloat(precio).toFixed(2) + '</span> 🏷️<br>';
            } else {
                body += '<strong>Precio:</strong> $' + parseFloat(precio).toFixed(2) + '<br>';
            }
            body += '<strong>Stock disponible:</strong> ' + stock + ' unidades<br>'
                + '<strong>Perecedero:</strong> ' + perecedero + '<br>'
                + (vencimiento !== '-' ? '<strong>Vencimiento:</strong> ' + vencimiento + '<br>' : '')
                + '<br><span style="color:' + (stock > 10 ? '#27ae60' : stock > 0 ? '#e67e22' : '#c0392b') + ';font-weight:700;">'
                + (stock > 10 ? '✅ Stock disponible' : stock > 0 ? '⚠️ Stock limitado' : '❌ Sin stock') + '</span>';
            document.getElementById('modal-producto-body').innerHTML = body;
            document.getElementById('modal-producto').style.display = 'flex';
        }
        function cerrarModalProducto() { document.getElementById('modal-producto').style.display = 'none'; }

        // ══════════════════════════════════════════════
        // MIS COMPRAS
        // ══════════════════════════════════════════════
        function compraSeleccionar(row) {
            document.querySelectorAll('#tabla-mis-compras tbody tr').forEach(function(r) { r.classList.remove('selected'); });
            row.classList.add('selected');
            compraSeleccionadaFila = row;
            document.getElementById('btn-ver-det-compra').disabled = false;
        }

        function compraVerDetalle() {
            if (!compraSeleccionadaFila) return;
            var r = compraSeleccionadaFila;
            var detalles = JSON.parse(r.dataset.detalles.replace(/&quot;/g, '"'));
            var txt = 'DETALLE DE COMPRA #' + r.dataset.id
                + '\nFecha:         ' + r.dataset.fecha
                + '\nForma de Pago: ' + r.dataset.formapago
                + '\n\nPRODUCTOS:\n----------------------------------------------\n';
            detalles.forEach(function(d) {
                txt += '- ' + d.nombre + '\n  Cantidad: ' + d.cantidad
                    + '\n  Precio: $' + d.precio + '\n  Subtotal: $' + d.subtotal + '\n\n';
            });
            txt += '----------------------------------------------\nTOTAL: $' + r.dataset.total;
            document.getElementById('modal-det-compra-body').textContent = txt;
            document.getElementById('modal-det-compra').style.display = 'flex';
        }

        function cerrarModalDetCompra() { document.getElementById('modal-det-compra').style.display = 'none'; }

        function comprasFiltrar() {
            var desde = document.getElementById('comp-desde').value;
            var hasta = document.getElementById('comp-hasta').value;
            document.querySelectorAll('#tabla-mis-compras tbody tr').forEach(function(row) {
                if (!row.dataset.fecha) return;
                var p = row.dataset.fecha.split(' ')[0].split('/');
                var f = p[2] + '-' + p[1] + '-' + p[0];
                row.style.display = ((!desde || f >= desde) && (!hasta || f <= hasta)) ? '' : 'none';
            });
        }

        function comprasLimpiar() {
            document.getElementById('comp-desde').value = '';
            document.getElementById('comp-hasta').value = '';
            document.querySelectorAll('#tabla-mis-compras tbody tr').forEach(function(r) { r.style.display = ''; });
            compraSeleccionadaFila = null;
            document.getElementById('btn-ver-det-compra').disabled = true;
        }

        // ══════════════════════════════════════════════
        // FAVORITOS
        // ══════════════════════════════════════════════
        function toggleFavorito(id, nombre, precio, stock) {
            fetch('/Favorito/Toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(id)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.ok) { alert('Error: ' + data.error); return; }
                var btn = document.getElementById('corazon-' + id);
                if (data.esFavorito) {
                    if (!favoritosItems.find(function(f) { return f.id === id; }))
                        favoritosItems.push({ id: id, nombre: nombre, precio: precio, stock: stock });
                    btn.textContent = '♥';
                    btn.classList.add('corazon-activo');
                } else {
                    favoritosItems = favoritosItems.filter(function(f) { return f.id !== id; });
                    btn.textContent = '♡';
                    btn.classList.remove('corazon-activo');
                }
                favRenderTabla();
            })
            .catch(function() { alert('Error de conexión.'); });
        }

        function sincronizarCorazones() {
            document.querySelectorAll('.btn-corazon').forEach(function(btn) {
                var id = parseInt(btn.id.replace('corazon-', ''));
                var esFav = favoritosItems.some(function(f) { return f.id === id; });
                btn.textContent = esFav ? '♥' : '♡';
                if (esFav) btn.classList.add('corazon-activo');
                else btn.classList.remove('corazon-activo');
            });
        }

        function abrirModalAgregarFavorito() {
            favProdSeleccionado = null;
            document.querySelectorAll('#tabla-buscar-prod tbody tr').forEach(function(r) { r.classList.remove('selected'); });
            document.getElementById('fav-buscar-input').value = '';
            favFiltrarBusqueda('');
            document.getElementById('modal-agregar-fav').style.display = 'flex';
        }

        function cerrarModalAgregarFav() { document.getElementById('modal-agregar-fav').style.display = 'none'; }

        function favSeleccionarProducto(row, id, nombre, precio, stock) {
            document.querySelectorAll('#tabla-buscar-prod tbody tr').forEach(function(r) { r.classList.remove('selected'); });
            row.classList.add('selected');
            favProdSeleccionado = { id: id, nombre: nombre, precio: precio, stock: stock };
        }

        function favFiltrarBusqueda(val) {
            var q = val.toLowerCase();
            document.querySelectorAll('#tabla-buscar-prod tbody tr').forEach(function(r) {
                r.style.display = (!q || (r.dataset.nom || '').includes(q)) ? '' : 'none';
            });
        }

        function favAgregarSeleccionado() {
            if (!favProdSeleccionado) { alert('Seleccione un producto.'); return; }
            if (favoritosItems.find(function(f) { return f.id === favProdSeleccionado.id; })) {
                alert('Ya está en favoritos.');
                return;
            }
            fetch('/Favorito/Toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(favProdSeleccionado.id)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.ok) { alert('Error: ' + data.error); return; }
                if (data.esFavorito) {
                    favoritosItems.push(favProdSeleccionado);
                    favRenderTabla();
                    sincronizarCorazones();
                }
                cerrarModalAgregarFav();
            })
            .catch(function() { alert('Error de conexión.'); });
        }

        function favEliminar(id) {
            if (!confirm('¿Eliminar de favoritos?')) return;
            fetch('/Favorito/Toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(id)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.ok) { alert('Error: ' + data.error); return; }
                favoritosItems = favoritosItems.filter(function(f) { return f.id !== id; });
                favRenderTabla();
                sincronizarCorazones();
            })
            .catch(function() { alert('Error de conexión.'); });
        }

        function favRenderTabla() {
            var tbody = document.getElementById('fav-tbody');
            if (!favoritosItems.length) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#aaa;padding:14px;">No tenés favoritos agregados.</td></tr>';
                document.getElementById('fav-total-lbl').textContent = 'Total de favoritos: 0';
                return;
            }
            tbody.innerHTML = '';
            favoritosItems.forEach(function(f) {
                tbody.innerHTML += '<tr>'
                    + '<td>' + f.id + '</td>'
                    + '<td>' + f.nombre + '</td>'
                    + '<td>$' + parseFloat(f.precio).toFixed(2) + '</td>'
                    + '<td>' + f.stock + '</td>'
                    + '<td><button class="btn-form-del" style="padding:2px 10px" onclick="favEliminar(' + f.id + ')">Eliminar</button></td>'
                    + '</tr>';
            });
            document.getElementById('fav-total-lbl').textContent = 'Total de favoritos: ' + favoritosItems.length;
        }

        // ══════════════════════════════════════════════
        // PERFIL
        // ══════════════════════════════════════════════
        function guardarPerfil() {
            var nom = document.getElementById('pf-nombre').value.trim();
            var ape = document.getElementById('pf-apellido').value.trim();
            if (!nom || !ape) { alert('Nombre y apellido son obligatorios.'); return; }
            document.getElementById('h-pf-nombre').value = nom;
            document.getElementById('h-pf-apellido').value = ape;
            document.getElementById('h-pf-dir').value = document.getElementById('pf-dir').value;
            document.getElementById('form-perfil').submit();
        }

        function cancelarPerfil(nom, ape, dir) {
            document.getElementById('pf-nombre').value = nom;
            document.getElementById('pf-apellido').value = ape;
            document.getElementById('pf-dir').value = dir;
        }

        // ══════════════════════════════════════════════
        // CAMBIO CONTRASEÑA
        // ══════════════════════════════════════════════
        function abrirModalCambioContrasena() { document.getElementById('modal-cambio-pass').style.display = 'flex'; }

        function cerrarModalCambioPass() {
            document.getElementById('modal-cambio-pass').style.display = 'none';
            ['pass-actual','pass-nueva','pass-confirmar'].forEach(function(id) {
                document.getElementById(id).value = '';
            });
        }

        function guardarCambioPass() {
            var actual = document.getElementById('pass-actual').value;
            var nueva = document.getElementById('pass-nueva').value;
            var conf = document.getElementById('pass-confirmar').value;
            if (!actual || !nueva || !conf) { alert('Complete todos los campos.'); return; }
            if (nueva !== conf) { alert('Las contraseñas no coinciden.'); return; }
            document.getElementById('h-pass-actual').value = actual;
            document.getElementById('h-pass-nueva').value = nueva;
            document.getElementById('form-cambio-pass').submit();
        }

        // ══════════════════════════════════════════════
        // SUSCRIPCIONES CLIENTE
        // ══════════════════════════════════════════════
        (function() {
            var _origShowPanelSuscCliente = window.showPanelCliente;
            window.showPanelCliente = function(name, btn) {
                _origShowPanelSuscCliente(name, btn);
                if (name === 'suscripcion') suscClienteCargar();
            };
        })();

        function suscClienteCargar() {
            fetch('/Suscripcion/MiSuscripcion')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.ok) return;
                var corona = document.getElementById('topbar-corona');
                if (corona) corona.style.display = data.tieneSuscripcion ? 'inline' : 'none';
                suscClienteRenderEstado(data);
                suscClienteRenderPlanes(data);
                suscClienteRenderHistorial(data);
            })
            .catch(function() {});
        }

        function suscClienteRenderEstado(data) {
            var box = document.getElementById('susc-estado-box');
            if (!box) return;
            if (!data.tieneSuscripcion) {
                box.innerHTML = '<div style="background:#fff;border:1.5px solid #e8c840;border-radius:8px;padding:16px;text-align:center;">'
                    + '<div style="font-size:32px;margin-bottom:8px;">🔓</div>'
                    + '<div style="font-size:13px;font-weight:700;color:#5a3e00;margin-bottom:6px;">No tenés suscripción activa</div>'
                    + '<div style="font-size:11px;color:#7a5500;">Elegí un plan y solicitá tu suscripción.</div>'
                    + '</div>';
                return;
            }
            var s = data.suscripcion;
            var corona = s.origen === 'Pago' ? '👑' : '<span style="filter:grayscale(1) opacity(0.6)">👑</span>';
            var colorDias = s.diasRestantes > 7 ? '#fff' : '#ffd7d7';
            var alertaDias = s.diasRestantes <= 7
                ? '<div style="background:#fdecea;border:1px solid #c0392b;border-radius:4px;padding:8px;font-size:11px;color:#c0392b;font-weight:700;margin-top:10px;">'
                  + '⚠️ Tu suscripción vence en ' + s.diasRestantes + ' días. ¡Renovála eligiendo un plan!</div>'
                : '';
            box.innerHTML = '<div style="background:linear-gradient(135deg,#27ae60 0%,#1e8449 100%);border-radius:8px;'
                + 'padding:16px 20px;color:#fff;display:flex;align-items:center;gap:16px;flex-wrap:wrap;">'
                + '<div style="font-size:36px;">' + corona + '</div>'
                + '<div style="flex:1;">'
                + '<div style="font-size:16px;font-weight:800;letter-spacing:0.5px;">SUSCRIPCIÓN ACTIVA</div>'
                + '<div style="font-size:13px;margin-top:4px;opacity:0.9;">Plan: <strong>' + s.planNombre + '</strong></div>'
                + '<div style="font-size:11px;margin-top:2px;opacity:0.8;">Desde ' + s.fechaInicio + ' hasta ' + s.fechaVencimiento + '</div>'
                + '</div>'
                + '<div style="text-align:center;background:rgba(0,0,0,0.15);border-radius:8px;padding:8px 16px;">'
                + '<div style="font-size:28px;font-weight:800;color:' + colorDias + ';">' + s.diasRestantes + '</div>'
                + '<div style="font-size:10px;font-weight:700;opacity:0.85;">DÍAS RESTANTES</div>'
                + '</div>'
                + '</div>'
                + alertaDias;
        }

        function suscClienteRenderPlanes(data) {
            var grid = document.getElementById('susc-planes-grid');
            if (!grid || !data.planes || !data.planes.length) return;
            grid.innerHTML = '';
            data.planes.forEach(function(p) {
                var desc = p.descripcion
                    ? '<div style="font-size:10px;color:#7a5500;margin:2px 0 4px;">' + p.descripcion + '</div>'
                    : '';
                grid.innerHTML += '<div style="background:#fff;border:1.5px solid #c8a000;border-radius:8px;'
                    + 'padding:14px;display:flex;flex-direction:column;gap:4px;text-align:center;">'
                    + '<div style="font-size:13px;font-weight:800;color:#3a2500;">' + p.nombre + '</div>'
                    + desc
                    + '<div style="font-size:22px;font-weight:700;color:#27ae60;margin:4px 0;">'
                    + '$' + parseFloat(p.precio).toFixed(2) + '</div>'
                    + '<div style="font-size:10px;color:#7a5500;">' + p.duracionMeses + ' mes/es</div>'
                    + '<button onclick="suscClienteSolicitar(' + p.id + ', \'' + p.nombre.replace(/'/g, "\\'") + '\')"'
                    + ' style="background:#d4a017;color:#2a1800;border:1.5px solid #8B6508;border-radius:4px;'
                    + 'padding:6px 0;font-size:10px;font-weight:700;cursor:pointer;margin-top:6px;">'
                    + 'SOLICITAR</button>'
                    + '</div>';
            });
        }

        function suscClienteRenderHistorial(data) {
            var tbody = document.getElementById('susc-historial-tbody');
            if (!tbody) return;
            if (!data.historial || !data.historial.length) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#aaa;padding:14px;">Sin historial.</td></tr>';
                return;
            }
            tbody.innerHTML = '';
            data.historial.forEach(function(p) {
                var colorEstado = p.estado === 'Aprobado' ? '#27ae60' : p.estado === 'Rechazado' ? '#c0392b' : '#e67e22';
                tbody.innerHTML += '<tr>'
                    + '<td>' + p.planNombre + '</td>'
                    + '<td style="font-weight:700;color:#27ae60;">$' + parseFloat(p.monto).toFixed(2) + '</td>'
                    + '<td>' + p.fechaSolicitud + '</td>'
                    + '<td>' + p.fechaAprobacion + '</td>'
                    + '<td><span style="font-weight:700;color:' + colorEstado + ';">' + p.estado + '</span>'
                    + (p.observacion ? '<br><span style="font-size:9px;color:#888;">' + p.observacion + '</span>' : '')
                    + '</td></tr>';
            });
        }

        function suscClienteSolicitar(planId, nombrePlan) {
            if (!confirm('¿Solicitar la suscripción al plan "' + nombrePlan + '"?\n\nEl administrador revisará y aprobará tu solicitud.')) return;
            var params = new URLSearchParams();
            params.append('planId', planId);
            fetch('/Suscripcion/Solicitar', { method: 'POST', body: params })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.ok) {
                    var t = document.createElement('div');
                    t.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;padding:10px 18px;'
                        + 'background:#d5f5e3;color:#1a5c38;border:1.5px solid #27ae60;border-radius:6px;font-size:12px;font-weight:600;';
                    t.textContent = '✓ ' + data.mensaje;
                    document.body.appendChild(t);
                    setTimeout(function() { t.remove(); }, 3000);
                    suscClienteCargar();
                } else {
                    alert(data.mensaje);
                }
            })
            .catch(function() { alert('Error de conexión.'); });
        }

        // ══════════════════════════════════════════════
        // INICIALIZACIÓN
        // ══════════════════════════════════════════════
        document.addEventListener('DOMContentLoaded', function() {
            // Fechas compras
            var hoy = new Date(), hace30 = new Date();
            hace30.setDate(hoy.getDate() - 30);
            function fmt(d) {
                return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
            }
            var cd = document.getElementById('comp-desde'); if (cd) cd.value = fmt(hace30);
            var ch = document.getElementById('comp-hasta'); if (ch) ch.value = fmt(hoy);

            // Carrito desde sessionStorage
            _carritoCargar();
            carritoActualizarBadge();

            // Cargar favoritos desde BD
            fetch('/Favorito/ObtenerFavoritos')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data.ok) return;
                    favoritosItems = data.items;
                    favRenderTabla();
                    sincronizarCorazones();
                });

            // Cargar suscripción para coronita
            suscClienteCargar();

            // Restaurar panel activo si viene de POST
            var panelActivo = '@(TempData["ActivePanel"] ?? "")';
            if (panelActivo && panelActivo !== 'inicio') {
                document.querySelectorAll('.panel').forEach(function(p) { p.classList.remove('active'); });
                document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });
                var el = document.getElementById('panel-' + panelActivo);
                if (el) el.classList.add('active');
            }
        });

        // Cerrar modales al click afuera
        document.getElementById('modal-carrito').addEventListener('click', function(e) {
            if (e.target === this) cerrarCarrito();
        });
        document.getElementById('modal-forma-pago').addEventListener('click', function(e) {
            if (e.target === this) cerrarModalFormaPago();
        });
        document.getElementById('modal-producto').addEventListener('click', function(e) {
            if (e.target === this) cerrarModalProducto();
        });
        document.getElementById('modal-det-compra').addEventListener('click', function(e) {
            if (e.target === this) cerrarModalDetCompra();
        });
        document.getElementById('modal-agregar-fav').addEventListener('click', function(e) {
            if (e.target === this) cerrarModalAgregarFav();
        });
        document.getElementById('modal-cambio-pass').addEventListener('click', function(e) {
            if (e.target === this) cerrarModalCambioPass();
        });
    </script>
}
