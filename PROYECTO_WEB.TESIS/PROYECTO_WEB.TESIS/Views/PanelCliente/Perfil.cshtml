@{
    ViewData["Title"] = "Mi Perfil";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    var cliente = ViewBag.Cliente as ENTIDADES.Cliente;
    var usuario = ViewBag.Usuario as ENTIDADES.Usuario;
}

<div class="panel-header">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="9" cy="6" r="4" stroke="#3a2500" stroke-width="1.3" fill="none" />
        <path d="M1 17c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="#3a2500" stroke-width="1.3" fill="none" />
    </svg>
    <h3>MI PERFIL</h3>
</div>
<div class="panel-body-content">

    <div style="max-width:580px;">
        <div style="background:#fff;border:1px solid #c8a000;border-radius:6px;padding:14px;margin-bottom:14px;">
            <div style="font-size:11px;font-weight:700;color:#7a5500;border-bottom:1px solid #e8c840;padding-bottom:5px;margin-bottom:10px;letter-spacing:0.4px;">
                DATOS PERSONALES
            </div>
            <form asp-controller="PanelCliente" asp-action="GuardarPerfil" method="post">
                <input type="hidden" name="Id" value="@cliente?.Id" />
                <div class="cli-form-grid">
                    <div class="form-field">
                        <label>NOMBRE:</label>
                        <input type="text" name="Nombre" value="@cliente?.Nombre" />
                    </div>
                    <div class="form-field">
                        <label>APELLIDO:</label>
                        <input type="text" name="Apellido" value="@cliente?.Apellido" />
                    </div>
                    <div class="form-field">
                        <label>DOCUMENTO:</label>
                        <input type="text" value="@cliente?.Documento" readonly />
                    </div>
                    <div class="form-field">
                        <label>DIRECCIÓN:</label>
                        <input type="text" name="Direccion" value="@cliente?.Direccion" />
                    </div>
                    <div class="form-field cli-form-full">
                        <label>EMAIL:</label>
                        <input type="email" value="@usuario?.Email" readonly title="El email no se puede modificar desde aquí" />
                    </div>
                </div>
                <div style="display:flex;gap:8px;margin-top:10px;">
                    <button type="submit" class="btn-dorado">GUARDAR CAMBIOS</button>
                    <a href="@Url.Action("Index", "PanelCliente")" class="btn-gris">CANCELAR</a>
                </div>
            </form>
        </div>

        <div style="background:#fff;border:1px solid #c8a000;border-radius:6px;padding:14px;">
            <div style="font-size:11px;font-weight:700;color:#7a5500;border-bottom:1px solid #e8c840;padding-bottom:5px;margin-bottom:10px;letter-spacing:0.4px;">
                CAMBIAR CONTRASEÑA
            </div>
            <form asp-controller="PanelCliente" asp-action="CambiarContrasena" method="post">
                <div class="form-field">
                    <label>CONTRASEÑA ACTUAL:</label>
                    <input type="password" name="contrasenaActual" style="max-width:300px;" />
                </div>
                <div class="form-field">
                    <label>NUEVA CONTRASEÑA:</label>
                    <input type="password" name="nuevaContrasena" id="nuevaPass" style="max-width:300px;" />
                </div>
                <div class="form-field">
                    <label>CONFIRMAR NUEVA CONTRASEÑA:</label>
                    <input type="password" name="confirmarContrasena" id="confirmarPass" style="max-width:300px;" />
                </div>
                <div id="pass-error" style="color:#c0392b;font-size:11px;margin-bottom:6px;display:none;">Las contraseñas no coinciden.</div>
                <button type="button" class="btn-azul" onclick="submitCambioPass()">CAMBIAR CONTRASEÑA</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', actualizarBadgeCarrito);

        function actualizarBadgeCarrito() {
            var carrito = JSON.parse(sessionStorage.getItem('carrito') || '[]');
            var total = carrito.reduce(function(s,i){ return s + i.cantidad; }, 0);
            var badge = document.querySelector('.carrito-badge');
            if (total > 0) {
                if (!badge) {
                    badge = document.createElement('span');
                    badge.className = 'carrito-badge';
                    document.querySelector('.carrito-icon-wrap').appendChild(badge);
                }
                badge.textContent = total;
                badge.style.display = 'flex';
            }
        }

        function submitCambioPass() {
            var nueva = document.getElementById('nuevaPass').value;
            var confirmar = document.getElementById('confirmarPass').value;
            var err = document.getElementById('pass-error');
            if (nueva !== confirmar) {
                err.style.display = 'block';
                return;
            }
            err.style.display = 'none';
            document.getElementById('nuevaPass').closest('form').submit();
        }
    </script>
}