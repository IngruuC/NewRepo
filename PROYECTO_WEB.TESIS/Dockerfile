FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /app
COPY PROYECTO_WEB.TESIS/ENTIDADES/ENTIDADES.csproj ENTIDADES/
COPY PROYECTO_WEB.TESIS/MODELO/MODELO.csproj MODELO/
COPY PROYECTO_WEB.TESIS/CONTROLADORA/CONTROLADORA.csproj CONTROLADORA/
COPY PROYECTO_WEB.TESIS/PROYECTO_WEB.TESIS/PROYECTO_WEB.TESIS.csproj PROYECTO_WEB.TESIS/
RUN dotnet restore PROYECTO_WEB.TESIS/PROYECTO_WEB.TESIS.csproj
COPY PROYECTO_WEB.TESIS/ENTIDADES/ ENTIDADES/
COPY PROYECTO_WEB.TESIS/MODELO/ MODELO/
COPY PROYECTO_WEB.TESIS/CONTROLADORA/ CONTROLADORA/
COPY PROYECTO_WEB.TESIS/PROYECTO_WEB.TESIS/ PROYECTO_WEB.TESIS/
RUN dotnet publish PROYECTO_WEB.TESIS/PROYECTO_WEB.TESIS.csproj -c Release -o /app/publish
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "PROYECTO_WEB.TESIS.dll"]